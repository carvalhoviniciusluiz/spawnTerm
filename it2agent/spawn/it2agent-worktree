#!/usr/bin/env sh
# it2agent-worktree — per-agent git-worktree + $PORT / namespace isolation.
#
# it2agent Phase 2 (#13). scope:external-tooling — glue that shells out to
# `git` and `it2agent-flag`; it never modifies iTerm2 source. It is the
# companion helper to `it2agent-spawn` (#10): when the feature flag
# `agent.worktree_isolation` is ON, each spawned agent gets its OWN git
# worktree on its OWN branch, plus a deterministic $IT2AGENT_PORT and a
# service/DB namespace prefix $IT2AGENT_NS, so parallel agents never collide
# on ports/DBs/services even though git worktrees only isolate files.
#
# ---------------------------------------------------------------------------
# THE PURE ALLOCATOR (subcommand `plan`, no side effects)
# ---------------------------------------------------------------------------
# Given (repo root, agent id, role, task, base port, span) it derives, purely
# and DETERMINISTICALLY (same inputs -> byte-identical outputs):
#
#   HASH       = sha1("<canonical-repo-path>|<agent-id>")  (hex)
#   branch     = it2agent/<slug>-<hash6>
#                  slug  = sanitize(role + "-" + id): lowercased, every char
#                          outside [a-z0-9] -> '-', runs collapsed, trimmed,
#                          truncated to 40; empty -> "agent".
#                  hash6 = first 6 hex chars of HASH (collision-safety anchor:
#                          two ids whose slugs collide still get distinct
#                          branches because the id feeds the hash).
#   worktree   = $IT2AGENT_WORKTREE_ROOT/<leaf>   (default root:
#                  <parent-of-repo>/.it2agent-worktrees/<repo-basename>)
#                  leaf = <slug>-<hash6>. Kept OUTSIDE the repo tree so it never
#                  shows up as untracked in the main checkout.
#   port       = base + (int(first 7 hex of HASH) % span)
#                  default base 41000, span 1000  => range 41000..41999.
#                  Deterministic *candidate*; the side-effecting layer may probe
#                  upward from here for a free TCP port (see `create`).
#   namespace  = <ns-role>_<hash6>
#                  ns-role = sanitize(role) into [a-z0-9_], leading letter
#                  guaranteed (prefixed 'a' if it would start with a digit),
#                  empty -> "agent". Safe as a DB/schema/service prefix.
#
# ---------------------------------------------------------------------------
# THE SIDE-EFFECT LAYER (subcommands `create` / `cleanup`, both --dry-run-able)
# ---------------------------------------------------------------------------
#   create   git worktree add on the derived branch, at the derived path.
#            Idempotent: re-running for the same agent id reuses the existing
#            worktree/branch. Handles a pre-existing branch and a dirty repo.
#            Prints the allocation (branch=/worktree=/port=/namespace=/...) on
#            stdout so `it2agent-spawn` can capture the values.
#   cleanup  Remove an agent's worktree + branch ONLY when it is safe:
#            refuses a DIRTY working tree and refuses an UNMERGED branch (work
#            not reachable from --base). --force overrides (destructive).
#
# --dry-run prints exactly the git commands it WOULD run (as `would-run: ...`
# lines) plus the resolved allocation, and executes nothing.
#
# Gating: `create`/`cleanup` self-gate on `agent.worktree_isolation` via
# `it2agent-flag` (fail-safe: flag absent / helper missing => OFF => no-op,
# exit 0), bypassable with --no-gate or IT2AGENT_FORCE=1, matching the
# it2agent-emit / it2agent-spawn convention. `plan`/`env` are pure and never
# gate.
#
# No external deps beyond `git`, a sha helper (shasum/sha1sum/openssl), and the
# optional `it2agent-flag`.
set -eu

PROG="it2agent-worktree"
FLAG_KEY="agent.worktree_isolation"

DEFAULT_BASE_PORT=41000
DEFAULT_SPAN=1000
SLUG_MAX=40

die() {
	printf '%s: %s\n' "$PROG" "$1" >&2
	exit 2
}

warn() {
	printf '%s: %s\n' "$PROG" "$1" >&2
}

# --- locate it2agent-flag (absolute) for the gate ---------------------------
script_dir() {
	d="$(dirname "$0")"
	(cd "$d" 2>/dev/null && pwd)
}

find_flag() {
	sd="$(script_dir)"
	if [ -n "$sd" ] && [ -x "$sd/../flags/it2agent-flag" ]; then
		fd="$(cd "$sd/../flags" && pwd)"
		printf '%s/it2agent-flag' "$fd"
		return 0
	fi
	if command -v it2agent-flag >/dev/null 2>&1; then
		command -v it2agent-flag
		return 0
	fi
	return 1
}

# gate_open: 0 (ON / bypassed) or 1 (OFF). Fail-safe OFF when the flag helper
# is missing or the flag is not set true.
gate_open() {
	[ "${IT2AGENT_FORCE:-}" = "1" ] && return 0
	[ "$NO_GATE" = "1" ] && return 0
	flag="$(find_flag 2>/dev/null)" || return 1
	if "$flag" "$FLAG_KEY" >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

# --- pure helpers ------------------------------------------------------------

# canonicalize a directory path (realpath without requiring realpath(1)).
canon_dir() {
	(cd "$1" 2>/dev/null && pwd -P)
}

# Canonicalize a possibly-nonexistent path: resolve symlinks on its longest
# existing prefix, then re-attach the missing suffix. Keeps our worktree paths
# byte-identical to what `git worktree` stores (e.g. /var -> /private/var on
# macOS), so registration/removal comparisons match.
canon_existing() {
	p="$1"; suffix=""
	while [ ! -e "$p" ] && [ "$p" != "/" ] && [ "$p" != "." ] && [ -n "$p" ]; do
		suffix="/$(basename "$p")$suffix"
		p="$(dirname "$p")"
	done
	if [ -d "$p" ]; then
		printf '%s%s' "$(cd "$p" && pwd -P)" "$suffix"
	else
		printf '%s%s' "$p" "$suffix"
	fi
}

# sha1 hex digest of stdin. Tries shasum, sha1sum, then openssl.
sha_hex() {
	if command -v shasum >/dev/null 2>&1; then
		shasum | cut -d' ' -f1
	elif command -v sha1sum >/dev/null 2>&1; then
		sha1sum | cut -d' ' -f1
	elif command -v openssl >/dev/null 2>&1; then
		openssl dgst -sha1 | sed -E 's/^.*= *//'
	else
		die "no sha helper found (need shasum, sha1sum, or openssl)"
	fi
}

# slugify $1 into a git-ref-safe leaf: lowercase, [a-z0-9] kept, others -> '-',
# runs collapsed, trimmed, truncated to $SLUG_MAX; empty -> "agent".
slugify() {
	s="$(printf '%s' "$1" \
		| tr '[:upper:]' '[:lower:]' \
		| tr -c 'a-z0-9' '-' \
		| sed -E 's/-+/-/g; s/^-//; s/-$//')"
	s="$(printf '%s' "$s" | cut -c1-"$SLUG_MAX" | sed -E 's/-$//')"
	[ -n "$s" ] || s="agent"
	printf '%s' "$s"
}

# nsify $1 into a DB/service-safe prefix: lowercase, [a-z0-9] kept, others ->
# '_', runs collapsed, trimmed; leading letter guaranteed; empty -> "agent".
nsify() {
	s="$(printf '%s' "$1" \
		| tr '[:upper:]' '[:lower:]' \
		| tr -c 'a-z0-9' '_' \
		| sed -E 's/_+/_/g; s/^_//; s/_$//')"
	[ -n "$s" ] || s="agent"
	case "$s" in
		[a-z]*) ;;
		*) s="a$s" ;;
	esac
	printf '%s' "$s"
}

is_uint() {
	case "$1" in
		'' | *[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

# compute_plan: sets BRANCH, WORKTREE, PORT, NAMESPACE, HASH, HASH6, SLUG from
# the resolved inputs REPO_ROOT, AGENT_ID, ROLE, TASK, BASE_PORT, SPAN. Pure.
compute_plan() {
	[ -n "$AGENT_ID" ] || die "an agent id is required (pass --id) to derive isolation"
	is_uint "$BASE_PORT" || die "--base-port must be a non-negative integer"
	is_uint "$SPAN" || die "--span must be a positive integer"
	[ "$SPAN" -ge 1 ] || die "--span must be >= 1"

	# HASH keys on the canonical repo path + agent id so two repos on one machine
	# don't collide on ports, and re-spawns of the same agent are stable.
	HASH="$(printf '%s|%s' "$REPO_ROOT" "$AGENT_ID" | sha_hex)"
	HASH6="$(printf '%s' "$HASH" | cut -c1-6)"

	slug_src="$AGENT_ID"
	[ -n "$ROLE" ] && slug_src="$ROLE-$AGENT_ID"
	SLUG="$(slugify "$slug_src")"

	BRANCH="it2agent/${SLUG}-${HASH6}"

	leaf="${SLUG}-${HASH6}"
	if [ -n "${IT2AGENT_WORKTREE_ROOT:-}" ]; then
		wt_root="$IT2AGENT_WORKTREE_ROOT"
	else
		repo_parent="$(dirname "$REPO_ROOT")"
		repo_base="$(basename "$REPO_ROOT")"
		wt_root="$repo_parent/.it2agent-worktrees/$repo_base"
	fi
	WORKTREE="$(canon_existing "$wt_root/$leaf")"

	# Lease dir sits beside the per-repo worktrees and is shared by every
	# concurrent spawn of this repo. Canonicalized like WORKTREE so independent
	# processes agree on the path. Computed here (pure) but only CREATED by the
	# side-effecting allocation path, so plan/env stay side-effect-free.
	WT_ROOT="$wt_root"
	LEASES_DIR="$(canon_existing "$wt_root/.leases")"

	# port int from first 7 hex chars (fits signed 32-bit shell arithmetic).
	port_hex="$(printf '%s' "$HASH" | cut -c1-7)"
	port_off=$(( 0x$port_hex % SPAN ))
	PORT=$(( BASE_PORT + port_off ))

	ns_src="agent"
	[ -n "$ROLE" ] && ns_src="$ROLE"
	NAMESPACE="$(nsify "$ns_src")_${HASH6}"
}

print_plan() {
	printf 'branch=%s\n' "$BRANCH"
	printf 'worktree=%s\n' "$WORKTREE"
	printf 'port=%s\n' "$PORT"
	printf 'namespace=%s\n' "$NAMESPACE"
	printf 'hash=%s\n' "$HASH6"
	printf 'repo=%s\n' "$REPO_ROOT"
}

# --- repo resolution ---------------------------------------------------------
resolve_repo() {
	# $1 = a --repo argument (may be empty => use $PWD). Sets REPO_ROOT to the
	# git top-level, canonicalized.
	base="${1:-$PWD}"
	[ -d "$base" ] || die "not a directory: $base"
	top="$(git -C "$base" rev-parse --show-toplevel 2>/dev/null)" \
		|| die "not inside a git repository: $base"
	REPO_ROOT="$(canon_dir "$top")"
}

# --- free-port probing (side-effect layer) -----------------------------------
# Deterministic candidate first; if taken (by a live TCP listener OR a live
# lease), walk upward within the range, wrapping, until a free port is found or
# the range is exhausted. See "port lease" below for the TOCTOU fix.
port_in_use() {
	p="$1"
	# Test/CI seam: pretend every port is TCP-free so lease logic can be
	# exercised deterministically regardless of what the host happens to bind.
	[ "${IT2AGENT_NO_TCP_PROBE:-}" = "1" ] && return 1
	# Best-effort, portable-ish. Prefer lsof; fall back to nc; else assume free.
	if command -v lsof >/dev/null 2>&1; then
		lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1 && return 0 || return 1
	elif command -v nc >/dev/null 2>&1; then
		nc -z 127.0.0.1 "$p" >/dev/null 2>&1 && return 0 || return 1
	fi
	return 1
}

# --- port lease (closes the TOCTOU gap in the probe) -------------------------
# The bare probe above is a check-then-use: two agents spawned near-simultaneously
# can both observe the same port as free and both bind it. A persisted lease under
# an allocation mutex makes the check-and-claim atomic across concurrent spawns.
#
# Storage: <LEASES_DIR>/<port>.lease, where LEASES_DIR = "$WT_ROOT/.leases"
# (alongside the per-repo worktrees, so `cleanup` and a future janitor can see
# it, and every concurrent spawn of the same repo shares one lease dir). Each
# lease is a small key=value record:
#     id=<agent-id>  repo=<repo-root>  pid=<owner-pid|0>  epoch=<unix-secs>  worktree=<path>
# A lease is STALE (reclaimable) when its worktree path no longer exists, OR it
# records a positive owner pid that is no longer alive. `pid=0` means "no live-pid
# tracking" (the default, since `create` itself is ephemeral) — such a lease is
# tied to its worktree only. Pass --lease-pid <n> to bind a lease to a durable
# process for tighter reclaim.

pid_alive() {
	# $1 = pid. 0 (true) iff it names a live process.
	case "$1" in
		'' | 0 | *[!0-9]*) return 1 ;;
	esac
	kill -0 "$1" 2>/dev/null
}

lease_path() {
	printf '%s/%s.lease' "$LEASES_DIR" "$1"
}

# lease_stale <lease-file>: 0 (true) if the lease is absent or reclaimable.
lease_stale() {
	lf="$1"
	[ -f "$lf" ] || return 0
	l_pid="$(sed -n 's/^pid=//p' "$lf" 2>/dev/null | head -1)"
	l_wt="$(sed -n 's/^worktree=//p' "$lf" 2>/dev/null | head -1)"
	# Worktree gone => stale.
	if [ -n "$l_wt" ] && [ ! -d "$l_wt" ]; then
		return 0
	fi
	# Positive owner pid that is dead => stale.
	if [ -n "$l_pid" ] && [ "$l_pid" != "0" ] && ! pid_alive "$l_pid"; then
		return 0
	fi
	return 1
}

write_lease() {
	# $1 = port. Writes/overwrites this agent's claim.
	lf="$(lease_path "$1")"
	epoch="$(date +%s 2>/dev/null || echo 0)"
	{
		printf 'id=%s\n' "$AGENT_ID"
		printf 'repo=%s\n' "$REPO_ROOT"
		printf 'pid=%s\n' "$LEASE_PID"
		printf 'epoch=%s\n' "$epoch"
		printf 'worktree=%s\n' "$WORKTREE"
	} > "$lf"
}

# --- allocation mutex: flock when available, atomic mkdir as POSIX fallback ---
LOCK_MODE=""
LOCK_DIR=""
acquire_alloc_lock() {
	mkdir -p "$LEASES_DIR" 2>/dev/null || die "cannot create leases dir: $LEASES_DIR"
	if command -v flock >/dev/null 2>&1; then
		LOCK_MODE="flock"
		# shellcheck disable=SC2093
		exec 9>"$LEASES_DIR/.alloc.lock" || die "cannot open allocation lock"
		flock 9 || die "cannot acquire allocation lock"
		return 0
	fi
	LOCK_MODE="mkdir"
	LOCK_DIR="$LEASES_DIR/.alloc.lock.d"
	tries=0
	while ! mkdir "$LOCK_DIR" 2>/dev/null; do
		# Reclaim a lock whose holder died (crash-safe, no sleep).
		holder="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
		if [ -n "$holder" ] && ! pid_alive "$holder"; then
			rm -rf "$LOCK_DIR" 2>/dev/null || true
			continue
		fi
		tries=$(( tries + 1 ))
		if [ "$tries" -ge 100000 ]; then
			die "cannot acquire allocation lock (held by pid ${holder:-?})"
		fi
	done
	printf '%s\n' "$$" > "$LOCK_DIR/pid" 2>/dev/null || true
}

release_alloc_lock() {
	case "$LOCK_MODE" in
		flock) exec 9>&- 2>/dev/null || true ;;
		mkdir) [ -n "$LOCK_DIR" ] && rm -rf "$LOCK_DIR" 2>/dev/null || true ;;
	esac
	LOCK_MODE=""
}

# lease_free_port: under the allocation mutex, start at the deterministic $PORT
# and walk upward within [BASE_PORT, BASE_PORT+SPAN), wrapping. The first port
# that is neither live-leased nor a live TCP listener is claimed with a lease and
# assigned to $PORT. Stale leases encountered on the way are reclaimed. With no
# contention this returns the deterministic candidate unchanged (back-compat).
lease_free_port() {
	acquire_alloc_lock
	start="$PORT"
	i=0
	cand="$start"
	while [ "$i" -lt "$SPAN" ]; do
		lf="$(lease_path "$cand")"
		if lease_stale "$lf"; then
			# Absent or reclaimable: drop any stale file, then require the port
			# to also be free of a live TCP listener before claiming it.
			[ -f "$lf" ] && rm -f "$lf" 2>/dev/null || true
			if ! port_in_use "$cand"; then
				PORT="$cand"
				write_lease "$cand"
				release_alloc_lock
				return 0
			fi
		fi
		i=$(( i + 1 ))
		off=$(( (cand - BASE_PORT + 1) % SPAN ))
		cand=$(( BASE_PORT + off ))
	done
	release_alloc_lock
	warn "no free/unleased port in range ${BASE_PORT}..$(( BASE_PORT + SPAN - 1 )); using deterministic candidate $start"
	PORT="$start"
	return 0
}

# release_leases_for_worktree: drop every lease this repo owns whose worktree
# matches $WORKTREE (the actually-claimed port may have advanced past the
# deterministic candidate, so we match on identity, not on the derived port).
release_leases_for_worktree() {
	[ -d "$LEASES_DIR" ] || return 0
	acquire_alloc_lock
	for lf in "$LEASES_DIR"/*.lease; do
		[ -f "$lf" ] || continue
		l_wt="$(sed -n 's/^worktree=//p' "$lf" 2>/dev/null | head -1)"
		if [ "$l_wt" = "$WORKTREE" ]; then
			rm -f "$lf" 2>/dev/null || true
		fi
	done
	release_alloc_lock
}

# --- git plan runner ---------------------------------------------------------
# run_git: in dry-run print the command; otherwise execute it (git chatter to
# stderr so stdout stays machine-parseable).
run_git() {
	if [ "$DRYRUN" = "1" ]; then
		printf 'would-run: git'
		for a in "$@"; do printf ' %s' "$a"; done
		printf '\n'
		return 0
	fi
	git "$@" >&2
}

# --- create ------------------------------------------------------------------
cmd_create() {
	compute_plan

	# Claim a free port under the allocation lease only when actually creating
	# (not in dry-run, so the printed plan stays deterministic and reproducible
	# on any machine). --no-probe forces the deterministic port as-is with no
	# lease (back-compat: the value is exactly the pure plan's).
	if [ "$DRYRUN" != "1" ] && [ "$NO_PROBE" != "1" ]; then
		lease_free_port
	fi

	# Emit the allocation FIRST so callers can capture values regardless of what
	# the git layer prints afterwards.
	print_plan

	if [ "$DRYRUN" = "1" ]; then
		printf 'would-run: mkdir -p %s\n' "$(dirname "$WORKTREE")"
		[ "$NO_PROBE" != "1" ] && printf 'would-run: lease port under %s (advancing on conflict)\n' "$LEASES_DIR"
	else
		mkdir -p "$(dirname "$WORKTREE")" || die "cannot create worktree parent: $(dirname "$WORKTREE")"
	fi

	# Idempotent: a worktree already registered at this path -> reuse it.
	if [ "$DRYRUN" != "1" ] && git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null \
		| grep -qxF "worktree $WORKTREE"; then
		warn "reusing existing worktree at $WORKTREE"
		return 0
	fi
	if [ -e "$WORKTREE" ] && [ "$DRYRUN" != "1" ]; then
		# Path exists but is not a registered worktree: refuse to clobber.
		die "worktree path already exists and is not a git worktree: $WORKTREE"
	fi

	# Does the branch already exist? If so, add a worktree ON it; else create it.
	if [ "$DRYRUN" != "1" ] \
		&& git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
		warn "branch $BRANCH already exists; adding a worktree on it"
		run_git -C "$REPO_ROOT" worktree add "$WORKTREE" "$BRANCH"
	else
		# New branch off current HEAD. A dirty main checkout does NOT block this:
		# `git worktree add -b` branches from HEAD (committed state), leaving the
		# spawner's uncommitted changes untouched in the main worktree.
		run_git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE"
	fi
}

# --- cleanup -----------------------------------------------------------------
detect_base() {
	# Default merge base for "is this branch merged" checks. Prefer the remote
	# HEAD, then a local main/master, then the repo's current branch.
	b="$(git -C "$REPO_ROOT" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
	if [ -n "$b" ] && git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$b"; then
		printf '%s' "$b"; return 0
	fi
	for cand in main master; do
		if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$cand"; then
			printf '%s' "$cand"; return 0
		fi
	done
	git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null
}

cmd_cleanup() {
	compute_plan
	print_plan

	base="$BASE_REF"
	[ -n "$base" ] || base="$(detect_base)"
	[ -n "$base" ] || die "cannot determine a base branch for the merged check (pass --base)"
	printf 'base=%s\n' "$base"

	if [ "$DRYRUN" = "1" ]; then
		printf 'would-run: git -C %s status --porcelain   (in worktree %s)\n' "$WORKTREE" "$WORKTREE"
		printf 'would-run: git -C %s branch --merged %s   (checking %s)\n' "$REPO_ROOT" "$base" "$BRANCH"
		printf 'would-run: git -C %s worktree remove %s\n' "$REPO_ROOT" "$WORKTREE"
		printf 'would-run: git -C %s branch -d %s\n' "$REPO_ROOT" "$BRANCH"
		printf 'would-run: git -C %s worktree prune\n' "$REPO_ROOT"
		printf 'would-run: release port lease(s) for %s under %s\n' "$WORKTREE" "$LEASES_DIR"
		return 0
	fi

	# The worktree may already be gone; the branch may still linger.
	wt_registered=0
	if git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null \
		| grep -qxF "worktree $WORKTREE"; then
		wt_registered=1
	fi
	branch_exists=0
	if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
		branch_exists=1
	fi

	if [ "$wt_registered" = "0" ] && [ "$branch_exists" = "0" ]; then
		warn "nothing to clean: no worktree at $WORKTREE and no branch $BRANCH"
		git -C "$REPO_ROOT" worktree prune >&2 2>/dev/null || true
		# Still release any lingering lease so a removed worktree never leaks one.
		release_leases_for_worktree
		return 0
	fi

	# SAFETY 1: refuse a dirty working tree (uncommitted or untracked changes).
	if [ "$wt_registered" = "1" ] && [ -d "$WORKTREE" ]; then
		dirty="$(git -C "$WORKTREE" status --porcelain 2>/dev/null)"
		if [ -n "$dirty" ]; then
			if [ "$FORCE" = "1" ]; then
				warn "worktree $WORKTREE is DIRTY; removing anyway (--force)"
			else
				warn "refusing to remove: worktree $WORKTREE has uncommitted/untracked changes"
				warn "commit or stash them, or pass --force to discard. Nothing was removed."
				return 1
			fi
		fi
	fi

	# SAFETY 2: refuse an unmerged branch (commits not reachable from base).
	if [ "$branch_exists" = "1" ]; then
		merged=0
		if git -C "$REPO_ROOT" branch --merged "$base" --format '%(refname:short)' 2>/dev/null \
			| grep -qxF "$BRANCH"; then
			merged=1
		fi
		if [ "$merged" = "0" ]; then
			if [ "$FORCE" = "1" ]; then
				warn "branch $BRANCH is NOT merged into $base; removing anyway (--force)"
			else
				ahead="$(git -C "$REPO_ROOT" rev-list --count "$base..$BRANCH" 2>/dev/null || echo '?')"
				warn "refusing to remove: branch $BRANCH has $ahead commit(s) not merged into $base"
				warn "merge it first, or pass --force to destroy the work. Nothing was removed."
				return 1
			fi
		fi
	fi

	# Safe (or forced): remove the worktree, then delete the branch, then prune.
	if [ "$wt_registered" = "1" ]; then
		if [ "$FORCE" = "1" ]; then
			git -C "$REPO_ROOT" worktree remove --force "$WORKTREE" >&2
		else
			git -C "$REPO_ROOT" worktree remove "$WORKTREE" >&2
		fi
	fi
	if [ "$branch_exists" = "1" ]; then
		if [ "$FORCE" = "1" ]; then
			git -C "$REPO_ROOT" branch -D "$BRANCH" >&2
		else
			git -C "$REPO_ROOT" branch -d "$BRANCH" >&2
		fi
	fi
	git -C "$REPO_ROOT" worktree prune >&2 2>/dev/null || true
	# Release the port lease(s) this worktree held so the port returns to the pool.
	release_leases_for_worktree
	warn "removed worktree $WORKTREE and branch $BRANCH"
}

# --- env ---------------------------------------------------------------------
# Print eval-able export lines for the spawned session. Pure (no git, no gate).
cmd_env() {
	compute_plan
	printf 'export IT2AGENT_PORT=%s\n' "$PORT"
	printf 'export IT2AGENT_NS=%s\n' "$NAMESPACE"
	printf 'export IT2AGENT_WORKTREE=%s\n' "$WORKTREE"
	printf 'export IT2AGENT_BRANCH=%s\n' "$BRANCH"
}

usage() {
	cat <<EOF
$PROG — per-agent git-worktree + \$IT2AGENT_PORT / \$IT2AGENT_NS isolation.

Usage:
  $PROG <command> [options]

Commands:
  plan       Print the derived allocation (pure, no side effects, no gate):
             branch, worktree path, port, namespace, hash, repo.
  env        Print eval-able export lines (IT2AGENT_PORT / _NS / _WORKTREE /
             _BRANCH). Pure, no side effects, no gate.
  create     Create the git worktree on the derived branch (gated). Prints the
             allocation on stdout. Idempotent; --dry-run prints the git plan.
  cleanup    Remove an agent's worktree + branch IF SAFE (gated): refuses a
             dirty working tree and an unmerged branch. --force overrides.
  -h,--help  Show this help.

Common options:
  --repo <dir>       Repo to operate on (default: \$PWD). Resolved to its git
                     top-level.
  --id <id>          Agent id (REQUIRED). Anchors the deterministic hash.
  --role <role>      Agent role (feeds the human-readable slug + namespace).
  --task <task>      Agent task (informational; not part of the hash).
  --base-port <n>    Base of the port range (default: $DEFAULT_BASE_PORT).
  --span <n>         Size of the port range (default: $DEFAULT_SPAN).
                     Deterministic port = base + (hash % span).

create options:
  --dry-run          Print the git commands + allocation; execute nothing.
  --no-probe         Skip free-port probing AND leasing; use the deterministic
                     port as-is (back-compat; identical to the pure plan).
  --lease-pid <n>    Bind the port lease to a durable process pid so it is
                     reclaimed when that process dies (default 0 = the lease is
                     tied to the worktree only).
  --no-gate          Bypass the feature-flag gate (local testing).

cleanup options:
  --base <ref>       Branch to test "merged into" against (default: auto-detect
                     origin/HEAD, then main/master, then current branch).
  --force            Override the dirty/unmerged safety refusals (DESTRUCTIVE).
  --dry-run          Print the git commands; execute nothing.
  --no-gate          Bypass the feature-flag gate (local testing).

Environment:
  IT2AGENT_WORKTREE_ROOT   Override the parent dir for all worktrees.
  IT2AGENT_FORCE=1         Bypass the feature-flag gate (like --no-gate).

Gating: create/cleanup emit/act only when "$FLAG_KEY" is ON
(checked via it2agent-flag). When OFF they no-op and exit 0 (fail-safe).
plan/env are pure and never gate.

Isolation model, port scheme, and cleanup safety: it2agent/spawn/WORKTREE.md
EOF
}

# --- parse -------------------------------------------------------------------
[ $# -ge 1 ] || { usage >&2; die "no command given"; }

CMD="$1"; shift
case "$CMD" in
	-h|--help|help) usage; exit 0 ;;
	plan|env|create|cleanup) ;;
	*) die "unknown command: $CMD (try --help)" ;;
esac

REPO_ARG=""
AGENT_ID=""
ROLE=""
TASK=""
BASE_PORT="$DEFAULT_BASE_PORT"
SPAN="$DEFAULT_SPAN"
DRYRUN=0
NO_GATE=0
NO_PROBE=0
FORCE=0
BASE_REF=""
LEASE_PID=0

[ "${IT2AGENT_FORCE:-}" = "1" ] && NO_GATE=1

while [ $# -gt 0 ]; do
	case "$1" in
		--repo) [ $# -ge 2 ] || die "--repo requires a <dir>"; REPO_ARG="$2"; shift 2 ;;
		--repo=*) REPO_ARG="${1#--repo=}"; shift ;;
		--id) [ $# -ge 2 ] || die "--id requires an <id>"; AGENT_ID="$2"; shift 2 ;;
		--id=*) AGENT_ID="${1#--id=}"; shift ;;
		--role) [ $# -ge 2 ] || die "--role requires a <role>"; ROLE="$2"; shift 2 ;;
		--role=*) ROLE="${1#--role=}"; shift ;;
		--task) [ $# -ge 2 ] || die "--task requires a <task>"; TASK="$2"; shift 2 ;;
		--task=*) TASK="${1#--task=}"; shift ;;
		--base-port) [ $# -ge 2 ] || die "--base-port requires a value"; BASE_PORT="$2"; shift 2 ;;
		--base-port=*) BASE_PORT="${1#--base-port=}"; shift ;;
		--span) [ $# -ge 2 ] || die "--span requires a value"; SPAN="$2"; shift 2 ;;
		--span=*) SPAN="${1#--span=}"; shift ;;
		--base) [ $# -ge 2 ] || die "--base requires a <ref>"; BASE_REF="$2"; shift 2 ;;
		--base=*) BASE_REF="${1#--base=}"; shift ;;
		--dry-run) DRYRUN=1; shift ;;
		--no-gate) NO_GATE=1; shift ;;
		--no-probe) NO_PROBE=1; shift ;;
		--lease-pid) [ $# -ge 2 ] || die "--lease-pid requires a value"; LEASE_PID="$2"; shift 2 ;;
		--lease-pid=*) LEASE_PID="${1#--lease-pid=}"; shift ;;
		--force) FORCE=1; shift ;;
		-h|--help) usage; exit 0 ;;
		--) shift; break ;;
		-*) die "unknown option: $1 (try --help)" ;;
		*) die "unexpected argument: $1 (try --help)" ;;
	esac
done

is_uint "$LEASE_PID" || die "--lease-pid must be a non-negative integer"

resolve_repo "$REPO_ARG"

case "$CMD" in
	plan)
		compute_plan
		print_plan
		;;
	env)
		cmd_env
		;;
	create)
		if ! gate_open; then
			warn "gate closed ($FLAG_KEY is OFF); no worktree created"
			exit 0
		fi
		cmd_create
		;;
	cleanup)
		if ! gate_open; then
			warn "gate closed ($FLAG_KEY is OFF); no cleanup performed"
			exit 0
		fi
		cmd_cleanup
		;;
esac
