#!/usr/bin/env sh
# it2agent-worktree — per-agent git-worktree + $PORT / namespace isolation.
#
# it2agent Phase 2 (#13). scope:external-tooling — glue that shells out to
# `git` and `it2agent-flag`; it never modifies iTerm2 source. It is the
# companion helper to `it2agent-spawn` (#10): when the feature flag
# `agent.worktree_isolation` is ON, each spawned agent gets its OWN git
# worktree on its OWN branch, plus a deterministic $IT2AGENT_PORT and a
# service/DB namespace prefix $IT2AGENT_NS, so parallel agents never collide
# on ports/DBs/services even though git worktrees only isolate files.
#
# ---------------------------------------------------------------------------
# THE PURE ALLOCATOR (subcommand `plan`, no side effects)
# ---------------------------------------------------------------------------
# Given (repo root, agent id, role, task, base port, span) it derives, purely
# and DETERMINISTICALLY (same inputs -> byte-identical outputs):
#
#   HASH       = sha1("<canonical-repo-path>|<agent-id>")  (hex)
#   branch     = it2agent/<slug>-<hash6>
#                  slug  = sanitize(role + "-" + id): lowercased, every char
#                          outside [a-z0-9] -> '-', runs collapsed, trimmed,
#                          truncated to 40; empty -> "agent".
#                  hash6 = first 6 hex chars of HASH (collision-safety anchor:
#                          two ids whose slugs collide still get distinct
#                          branches because the id feeds the hash).
#   worktree   = $IT2AGENT_WORKTREE_ROOT/<leaf>   (default root:
#                  <parent-of-repo>/.it2agent-worktrees/<repo-basename>)
#                  leaf = <slug>-<hash6>. Kept OUTSIDE the repo tree so it never
#                  shows up as untracked in the main checkout.
#   port       = base + (int(first 7 hex of HASH) % span)
#                  default base 41000, span 1000  => range 41000..41999.
#                  Deterministic *candidate*; the side-effecting layer may probe
#                  upward from here for a free TCP port (see `create`).
#   namespace  = <ns-role>_<hash6>
#                  ns-role = sanitize(role) into [a-z0-9_], leading letter
#                  guaranteed (prefixed 'a' if it would start with a digit),
#                  empty -> "agent". Safe as a DB/schema/service prefix.
#
# ---------------------------------------------------------------------------
# THE SIDE-EFFECT LAYER (subcommands `create` / `cleanup`, both --dry-run-able)
# ---------------------------------------------------------------------------
#   create   git worktree add on the derived branch, at the derived path.
#            Idempotent: re-running for the same agent id reuses the existing
#            worktree/branch. Handles a pre-existing branch and a dirty repo.
#            Prints the allocation (branch=/worktree=/port=/namespace=/...) on
#            stdout so `it2agent-spawn` can capture the values.
#   cleanup  Remove an agent's worktree + branch ONLY when it is safe:
#            refuses a DIRTY working tree and refuses an UNMERGED branch (work
#            not reachable from --base). --force overrides (destructive).
#
# --dry-run prints exactly the git commands it WOULD run (as `would-run: ...`
# lines) plus the resolved allocation, and executes nothing.
#
# Gating: `create`/`cleanup` self-gate on `agent.worktree_isolation` via
# `it2agent-flag` (fail-safe: flag absent / helper missing => OFF => no-op,
# exit 0), bypassable with --no-gate or IT2AGENT_FORCE=1, matching the
# it2agent-emit / it2agent-spawn convention. `plan`/`env` are pure and never
# gate.
#
# No external deps beyond `git`, a sha helper (shasum/sha1sum/openssl), and the
# optional `it2agent-flag`.
set -eu

PROG="it2agent-worktree"
FLAG_KEY="agent.worktree_isolation"
# Sub-flag for the canonical-port feature (item 4). Fail-safe OFF: the canonical
# singleton lease is only touched when this is ON (or bypassed via --no-gate /
# IT2AGENT_FORCE). It is independent of the worktree_isolation gate above.
FLAG_KEY_CANONICAL="agent.canonical_port"
# Sub-flags for the service-isolation features (--isolate, items 5+6). Each is
# fail-safe OFF and independent: the corresponding export is only emitted when
# its flag is ON (or bypassed via --no-gate / IT2AGENT_FORCE). ENV-ONLY — we
# export variables the project's own compose/DB tooling reads; we never run
# docker or connect to Postgres.
FLAG_KEY_ISOLATE_DOCKER="agent.isolate_docker"
FLAG_KEY_ISOLATE_DB="agent.isolate_db"

DEFAULT_BASE_PORT=41000
DEFAULT_SPAN=1000
# Default base for the canonical (project-normal) port. The first --ports name
# maps to this number, the second to +1, and so on. Override with
# --canonical-port <base>.
DEFAULT_CANONICAL_BASE=3000
SLUG_MAX=40

# Field separator for the ls/status reporter's intermediate records. A US (unit
# separator, \037) is deliberate: it is NOT IFS-whitespace, so `read` preserves
# EMPTY fields instead of coalescing them (a tab would collapse an empty
# "changes"/"reason" field and shift every later column). It also never occurs
# in a branch name or a real worktree path.
REC_SEP="$(printf '\037')"

die() {
	printf '%s: %s\n' "$PROG" "$1" >&2
	exit 2
}

warn() {
	printf '%s: %s\n' "$PROG" "$1" >&2
}

# --- locate it2agent-flag (absolute) for the gate ---------------------------
script_dir() {
	d="$(dirname "$0")"
	(cd "$d" 2>/dev/null && pwd)
}

find_flag() {
	sd="$(script_dir)"
	if [ -n "$sd" ] && [ -x "$sd/../flags/it2agent-flag" ]; then
		fd="$(cd "$sd/../flags" && pwd)"
		printf '%s/it2agent-flag' "$fd"
		return 0
	fi
	if command -v it2agent-flag >/dev/null 2>&1; then
		command -v it2agent-flag
		return 0
	fi
	return 1
}

# gate_open: 0 (ON / bypassed) or 1 (OFF). Fail-safe OFF when the flag helper
# is missing or the flag is not set true.
gate_open() {
	[ "${IT2AGENT_FORCE:-}" = "1" ] && return 0
	[ "$NO_GATE" = "1" ] && return 0
	flag="$(find_flag 2>/dev/null)" || return 1
	if "$flag" "$FLAG_KEY" >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

# --- pure helpers ------------------------------------------------------------

# canonicalize a directory path (realpath without requiring realpath(1)).
canon_dir() {
	(cd "$1" 2>/dev/null && pwd -P)
}

# Canonicalize a possibly-nonexistent path: resolve symlinks on its longest
# existing prefix, then re-attach the missing suffix. Keeps our worktree paths
# byte-identical to what `git worktree` stores (e.g. /var -> /private/var on
# macOS), so registration/removal comparisons match.
canon_existing() {
	p="$1"; suffix=""
	while [ ! -e "$p" ] && [ "$p" != "/" ] && [ "$p" != "." ] && [ -n "$p" ]; do
		suffix="/$(basename "$p")$suffix"
		p="$(dirname "$p")"
	done
	if [ -d "$p" ]; then
		printf '%s%s' "$(cd "$p" && pwd -P)" "$suffix"
	else
		printf '%s%s' "$p" "$suffix"
	fi
}

# sha1 hex digest of stdin. Tries shasum, sha1sum, then openssl.
sha_hex() {
	if command -v shasum >/dev/null 2>&1; then
		shasum | cut -d' ' -f1
	elif command -v sha1sum >/dev/null 2>&1; then
		sha1sum | cut -d' ' -f1
	elif command -v openssl >/dev/null 2>&1; then
		openssl dgst -sha1 | sed -E 's/^.*= *//'
	else
		die "no sha helper found (need shasum, sha1sum, or openssl)"
	fi
}

# slugify $1 into a git-ref-safe leaf: lowercase, [a-z0-9] kept, others -> '-',
# runs collapsed, trimmed, truncated to $SLUG_MAX; empty -> "agent".
slugify() {
	s="$(printf '%s' "$1" \
		| tr '[:upper:]' '[:lower:]' \
		| tr -c 'a-z0-9' '-' \
		| sed -E 's/-+/-/g; s/^-//; s/-$//')"
	s="$(printf '%s' "$s" | cut -c1-"$SLUG_MAX" | sed -E 's/-$//')"
	[ -n "$s" ] || s="agent"
	printf '%s' "$s"
}

# nsify $1 into a DB/service-safe prefix: lowercase, [a-z0-9] kept, others ->
# '_', runs collapsed, trimmed; leading letter guaranteed; empty -> "agent".
nsify() {
	s="$(printf '%s' "$1" \
		| tr '[:upper:]' '[:lower:]' \
		| tr -c 'a-z0-9' '_' \
		| sed -E 's/_+/_/g; s/^_//; s/_$//')"
	[ -n "$s" ] || s="agent"
	case "$s" in
		[a-z]*) ;;
		*) s="a$s" ;;
	esac
	printf '%s' "$s"
}

is_uint() {
	case "$1" in
		'' | *[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

# sanitize_portname $1 into a lowercase [a-z0-9_] token for a --ports name:
# lowercase, others -> '_', runs collapsed, trimmed. Empty -> "".
sanitize_portname() {
	printf '%s' "$1" \
		| tr '[:upper:]' '[:lower:]' \
		| tr -c 'a-z0-9_' '_' \
		| sed -E 's/_+/_/g; s/^_//; s/_$//'
}

# portkey $1: the UPPER-cased env-var suffix for a (sanitized) port name, so
# name "web" -> IT2AGENT_PORT_WEB. Input is already [a-z0-9_].
portkey() {
	printf '%s' "$1" | tr '[:lower:]' '[:upper:]'
}

# port_names_list: echo the sanitized --ports names, one per line. Empty output
# means "no --ports given" (single default port, byte-identical to #13). Depends
# on the PORTS_CSV global set by the parser.
port_names_list() {
	[ -n "$PORTS_CSV" ] || return 0
	# Trailing newline is required so `read` does not drop the final (unterminated)
	# name — PORTS_CSV has no trailing comma, so tr would otherwise leave the last
	# token without a newline.
	printf '%s\n' "$PORTS_CSV" | tr ',' '\n' | while IFS= read -r raw; do
		nm="$(sanitize_portname "$raw")"
		[ -n "$nm" ] && printf '%s\n' "$nm"
	done
}

# port_candidate $1 = port name: deterministic candidate port for a NAMED port,
# folding the name into the hash so several named ports for one agent don't
# collide with each other: base + (int(first 7 hex of sha1("<repo>|<id>|<name>"))
# % span). The unnamed (default) port keeps using compute_plan's HASH (no name),
# so behavior without --ports is byte-identical to #13.
port_candidate() {
	_h="$(printf '%s|%s|%s' "$REPO_ROOT" "$AGENT_ID" "$1" | sha_hex)"
	_ph="$(printf '%s' "$_h" | cut -c1-7)"
	printf '%s' "$(( BASE_PORT + (0x$_ph % SPAN) ))"
}

# compute_wt_root: sets WT_ROOT (the per-repo worktree parent) and LEASES_DIR
# (the shared lease dir beside it) from REPO_ROOT alone — no agent id needed, so
# the read-only reporters (ls/status) can locate leases without a plan. Pure.
# The lease dir is shared by every concurrent spawn of this repo and is
# canonicalized like WORKTREE so independent processes agree on the path. It is
# only ever CREATED by the side-effecting allocation path, never here.
compute_wt_root() {
	if [ -n "${IT2AGENT_WORKTREE_ROOT:-}" ]; then
		WT_ROOT="$IT2AGENT_WORKTREE_ROOT"
	else
		repo_parent="$(dirname "$REPO_ROOT")"
		repo_base="$(basename "$REPO_ROOT")"
		WT_ROOT="$repo_parent/.it2agent-worktrees/$repo_base"
	fi
	LEASES_DIR="$(canon_existing "$WT_ROOT/.leases")"
}

# compute_plan: sets BRANCH, WORKTREE, PORT, NAMESPACE, HASH, HASH6, SLUG from
# the resolved inputs REPO_ROOT, AGENT_ID, ROLE, TASK, BASE_PORT, SPAN. Pure.
compute_plan() {
	[ -n "$AGENT_ID" ] || die "an agent id is required (pass --id) to derive isolation"
	is_uint "$BASE_PORT" || die "--base-port must be a non-negative integer"
	is_uint "$SPAN" || die "--span must be a positive integer"
	[ "$SPAN" -ge 1 ] || die "--span must be >= 1"

	# HASH keys on the canonical repo path + agent id so two repos on one machine
	# don't collide on ports, and re-spawns of the same agent are stable.
	HASH="$(printf '%s|%s' "$REPO_ROOT" "$AGENT_ID" | sha_hex)"
	HASH6="$(printf '%s' "$HASH" | cut -c1-6)"

	slug_src="$AGENT_ID"
	[ -n "$ROLE" ] && slug_src="$ROLE-$AGENT_ID"
	SLUG="$(slugify "$slug_src")"

	BRANCH="it2agent/${SLUG}-${HASH6}"

	leaf="${SLUG}-${HASH6}"
	compute_wt_root
	WORKTREE="$(canon_existing "$WT_ROOT/$leaf")"

	# port int from first 7 hex chars (fits signed 32-bit shell arithmetic).
	port_hex="$(printf '%s' "$HASH" | cut -c1-7)"
	port_off=$(( 0x$port_hex % SPAN ))
	PORT=$(( BASE_PORT + port_off ))

	ns_src="agent"
	[ -n "$ROLE" ] && ns_src="$ROLE"
	NAMESPACE="$(nsify "$ns_src")_${HASH6}"
}

print_plan() {
	printf 'branch=%s\n' "$BRANCH"
	printf 'worktree=%s\n' "$WORKTREE"
	printf 'port=%s\n' "$PORT"
	printf 'namespace=%s\n' "$NAMESPACE"
	printf 'hash=%s\n' "$HASH6"
	printf 'repo=%s\n' "$REPO_ROOT"
}

# LEASED_PORTS: newline list of "<name> <port>" records for the NAMED ports of a
# --ports request (empty when --ports was not given). Set by
# compute_ports_deterministic (pure) or lease_all_ports (side-effecting).
LEASED_PORTS=""

# print_extra_ports: emit one `port_<name>=<n>` line per NAMED port. No output
# without --ports, so the plan stays byte-identical to #13 in that case.
print_extra_ports() {
	[ -n "$LEASED_PORTS" ] || return 0
	printf '%s' "$LEASED_PORTS" | while IFS=' ' read -r _nm _p; do
		[ -n "$_nm" ] || continue
		printf 'port_%s=%s\n' "$_nm" "$_p"
	done
}

# compute_ports_deterministic: PURE. Fill LEASED_PORTS + PORT from the
# per-name deterministic candidates (no lease, no probe). Used by plan/env and by
# create in --dry-run / --no-probe. Without --ports it leaves PORT as compute_plan
# set it (byte-identical to #13).
compute_ports_deterministic() {
	LEASED_PORTS=""
	_names="$(port_names_list)"
	[ -n "$_names" ] || return 0
	_first=""
	for _nm in $_names; do
		_cand="$(port_candidate "$_nm")"
		[ -n "$_first" ] || _first="$_cand"
		LEASED_PORTS="${LEASED_PORTS}${_nm} ${_cand}
"
	done
	PORT="$_first"
}

# --- repo resolution ---------------------------------------------------------
resolve_repo() {
	# $1 = a --repo argument (may be empty => use $PWD). Sets REPO_ROOT to the
	# git top-level, canonicalized.
	base="${1:-$PWD}"
	[ -d "$base" ] || die "not a directory: $base"
	top="$(git -C "$base" rev-parse --show-toplevel 2>/dev/null)" \
		|| die "not inside a git repository: $base"
	REPO_ROOT="$(canon_dir "$top")"
}

# --- free-port probing (side-effect layer) -----------------------------------
# Deterministic candidate first; if taken (by a live TCP listener OR a live
# lease), walk upward within the range, wrapping, until a free port is found or
# the range is exhausted. See "port lease" below for the TOCTOU fix.
port_in_use() {
	p="$1"
	# Test/CI seam: pretend every port is TCP-free so lease logic can be
	# exercised deterministically regardless of what the host happens to bind.
	[ "${IT2AGENT_NO_TCP_PROBE:-}" = "1" ] && return 1
	# Best-effort, portable-ish. Prefer lsof; fall back to nc; else assume free.
	if command -v lsof >/dev/null 2>&1; then
		lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1 && return 0 || return 1
	elif command -v nc >/dev/null 2>&1; then
		nc -z 127.0.0.1 "$p" >/dev/null 2>&1 && return 0 || return 1
	fi
	return 1
}

# --- port lease (closes the TOCTOU gap in the probe) -------------------------
# The bare probe above is a check-then-use: two agents spawned near-simultaneously
# can both observe the same port as free and both bind it. A persisted lease under
# an allocation mutex makes the check-and-claim atomic across concurrent spawns.
#
# Storage: <LEASES_DIR>/<port>.lease, where LEASES_DIR = "$WT_ROOT/.leases"
# (alongside the per-repo worktrees, so `cleanup` and a future janitor can see
# it, and every concurrent spawn of the same repo shares one lease dir). Each
# lease is a small key=value record:
#     id=<agent-id>  repo=<repo-root>  pid=<owner-pid|0>  epoch=<unix-secs>  worktree=<path>
# A lease is STALE (reclaimable) when its worktree path no longer exists, OR it
# records a positive owner pid that is no longer alive. `pid=0` means "no live-pid
# tracking" (the default, since `create` itself is ephemeral) — such a lease is
# tied to its worktree only. Pass --lease-pid <n> to bind a lease to a durable
# process for tighter reclaim.

pid_alive() {
	# $1 = pid. 0 (true) iff it names a live process.
	case "$1" in
		'' | 0 | *[!0-9]*) return 1 ;;
	esac
	kill -0 "$1" 2>/dev/null
}

lease_path() {
	printf '%s/%s.lease' "$LEASES_DIR" "$1"
}

# lease_stale <lease-file>: 0 (true) if the lease is absent or reclaimable.
lease_stale() {
	lf="$1"
	[ -f "$lf" ] || return 0
	l_pid="$(sed -n 's/^pid=//p' "$lf" 2>/dev/null | head -1)"
	l_wt="$(sed -n 's/^worktree=//p' "$lf" 2>/dev/null | head -1)"
	# Worktree gone => stale.
	if [ -n "$l_wt" ] && [ ! -d "$l_wt" ]; then
		return 0
	fi
	# Positive owner pid that is dead => stale.
	if [ -n "$l_pid" ] && [ "$l_pid" != "0" ] && ! pid_alive "$l_pid"; then
		return 0
	fi
	return 1
}

write_lease() {
	# $1 = port. Writes/overwrites this agent's claim.
	lf="$(lease_path "$1")"
	epoch="$(date +%s 2>/dev/null || echo 0)"
	{
		printf 'id=%s\n' "$AGENT_ID"
		printf 'repo=%s\n' "$REPO_ROOT"
		printf 'pid=%s\n' "$LEASE_PID"
		printf 'epoch=%s\n' "$epoch"
		printf 'worktree=%s\n' "$WORKTREE"
	} > "$lf"
}

# --- allocation mutex: flock when available, atomic mkdir as POSIX fallback ---
LOCK_MODE=""
LOCK_DIR=""
acquire_alloc_lock() {
	mkdir -p "$LEASES_DIR" 2>/dev/null || die "cannot create leases dir: $LEASES_DIR"
	if command -v flock >/dev/null 2>&1; then
		LOCK_MODE="flock"
		# shellcheck disable=SC2093
		exec 9>"$LEASES_DIR/.alloc.lock" || die "cannot open allocation lock"
		flock 9 || die "cannot acquire allocation lock"
		return 0
	fi
	LOCK_MODE="mkdir"
	LOCK_DIR="$LEASES_DIR/.alloc.lock.d"
	tries=0
	while ! mkdir "$LOCK_DIR" 2>/dev/null; do
		# Reclaim a lock whose holder died (crash-safe, no sleep).
		holder="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
		if [ -n "$holder" ] && ! pid_alive "$holder"; then
			rm -rf "$LOCK_DIR" 2>/dev/null || true
			continue
		fi
		tries=$(( tries + 1 ))
		if [ "$tries" -ge 100000 ]; then
			die "cannot acquire allocation lock (held by pid ${holder:-?})"
		fi
	done
	printf '%s\n' "$$" > "$LOCK_DIR/pid" 2>/dev/null || true
}

release_alloc_lock() {
	case "$LOCK_MODE" in
		flock) exec 9>&- 2>/dev/null || true ;;
		mkdir) [ -n "$LOCK_DIR" ] && rm -rf "$LOCK_DIR" 2>/dev/null || true ;;
	esac
	LOCK_MODE=""
}

# Ports claimed WITHIN the current allocation (space-separated). Consulted by
# claim_one_port so two named ports of the SAME create never land on one number
# even before their shared worktree exists on disk.
CLAIMED_PORTS=""

# claim_one_port $1 = start candidate. The allocation mutex MUST already be held.
# Walk upward within [BASE_PORT, BASE_PORT+SPAN), wrapping, for a port that is not
# already claimed in THIS allocation, not held by a live lease, and not a live TCP
# listener; claim it with a lease and echo it. Stale leases on the way are
# reclaimed. On exhaustion, echo the start candidate and return 1.
claim_one_port() {
	_start="$1"; _i=0; _cand="$_start"
	while [ "$_i" -lt "$SPAN" ]; do
		case " $CLAIMED_PORTS " in
			*" $_cand "*) ;;   # already claimed in this allocation; skip
			*)
				_lf="$(lease_path "$_cand")"
				if lease_stale "$_lf"; then
					[ -f "$_lf" ] && rm -f "$_lf" 2>/dev/null || true
					if ! port_in_use "$_cand"; then
						write_lease "$_cand"
						CLAIMED_PORTS="$CLAIMED_PORTS $_cand"
						printf '%s' "$_cand"
						return 0
					fi
				fi
				;;
		esac
		_i=$(( _i + 1 ))
		_off=$(( (_cand - BASE_PORT + 1) % SPAN ))
		_cand=$(( BASE_PORT + _off ))
	done
	printf '%s' "$_start"
	return 1
}

# lease_all_ports: side-effecting allocation. Under a single hold of the mutex,
# claim a lease for the default (unnamed) port OR for each --ports name. Sets PORT
# to the first/only leased port (bare $IT2AGENT_PORT, back-compat) and fills
# LEASED_PORTS with the "<name> <port>" records for NAMED ports. With no
# contention and no --ports this returns the deterministic candidate unchanged.
lease_all_ports() {
	acquire_alloc_lock
	CLAIMED_PORTS=""
	LEASED_PORTS=""
	_names="$(port_names_list)"
	if [ -z "$_names" ]; then
		_p="$(claim_one_port "$PORT")" \
			|| warn "no free/unleased port in range ${BASE_PORT}..$(( BASE_PORT + SPAN - 1 )); using deterministic candidate $PORT"
		PORT="$_p"
	else
		_first=""
		for _nm in $_names; do
			_cand="$(port_candidate "$_nm")"
			_p="$(claim_one_port "$_cand")" \
				|| warn "no free/unleased port for '$_nm' in range ${BASE_PORT}..$(( BASE_PORT + SPAN - 1 )); using deterministic candidate $_cand"
			[ -n "$_first" ] || _first="$_p"
			LEASED_PORTS="${LEASED_PORTS}${_nm} ${_p}
"
		done
		PORT="$_first"
	fi
	release_alloc_lock
}

# release_leases_for_worktree: drop every lease this repo owns whose worktree
# matches $WORKTREE (the actually-claimed port may have advanced past the
# deterministic candidate, so we match on identity, not on the derived port).
release_leases_for_worktree() {
	[ -d "$LEASES_DIR" ] || return 0
	acquire_alloc_lock
	for lf in "$LEASES_DIR"/*.lease; do
		[ -f "$lf" ] || continue
		l_wt="$(sed -n 's/^worktree=//p' "$lf" 2>/dev/null | head -1)"
		if [ "$l_wt" = "$WORKTREE" ]; then
			rm -f "$lf" 2>/dev/null || true
		fi
	done
	release_alloc_lock
}

# --- canonical port (item 4): a per-(repo, port-name) SINGLETON lease ---------
# Beyond the always-unique dynamic port, an agent may additionally hold the
# project's NORMAL dev port (e.g. 3000) for a named port, so the "focused" agent
# answers on the address of record. Exactly one agent per repo holds each name's
# canonical value at a time. We HAND OVER THE NUMBER (exported as
# IT2AGENT_CANONICAL_PORT_<NAME>); we do NOT proxy/forward traffic — that is
# future daemon work (#3). Stored beside the dynamic leases as
# <LEASES_DIR>/canonical-<name>.lease, with the same stale-reclaim rule
# (worktree gone, or a positive owner pid that is dead — see lease_stale).
#
# Self-gated on agent.canonical_port: the caller only invokes these when
# canonical_gate_open is true (fail-safe OFF, bypassable with --no-gate /
# IT2AGENT_FORCE for tests). Reuses the dynamic allocation mutex so acquisition
# is atomic against concurrent spawns.

canonical_gate_open() {
	[ "${IT2AGENT_FORCE:-}" = "1" ] && return 0
	[ "$NO_GATE" = "1" ] && return 0
	flag="$(find_flag 2>/dev/null)" || return 1
	"$flag" "$FLAG_KEY_CANONICAL" >/dev/null 2>&1
}

canonical_lease_path() {
	printf '%s/canonical-%s.lease' "$LEASES_DIR" "$1"
}

# canonical_names: the port names the canonical feature operates on — the --ports
# names when given, else a single implicit "web" (so a bare spawn with the flag ON
# still has a name to key IT2AGENT_CANONICAL_PORT_WEB on, without perturbing the
# dynamic single-port back-compat path).
canonical_names() {
	_n="$(port_names_list)"
	if [ -n "$_n" ]; then
		printf '%s' "$_n"
	else
		printf 'web\n'
	fi
}

# CANONICAL_RESULT: newline "<name> <canonical-port>" records this agent holds
# after acquire_all_canonical (empty for names a live peer already owns).
CANONICAL_RESULT=""

# acquire_all_canonical: under the mutex, try to take each canonical name for this
# agent. A name is taken when its lease is absent, stale, already ours (same
# worktree — idempotent re-spawn), or when --canonical-takeover forces a handover;
# otherwise it is left with its current live owner (singleton). The canonical
# number is CANONICAL_BASE + index-of-name.
acquire_all_canonical() {
	acquire_alloc_lock
	CANONICAL_RESULT=""
	_idx=0
	_epoch="$(date +%s 2>/dev/null || echo 0)"
	for _nm in $(canonical_names); do
		_cp=$(( CANONICAL_BASE + _idx ))
		_idx=$(( _idx + 1 ))
		_lf="$(canonical_lease_path "$_nm")"
		_take=0
		if [ ! -f "$_lf" ]; then
			_take=1
		else
			_owner_wt="$(sed -n 's/^worktree=//p' "$_lf" 2>/dev/null | head -1)"
			if [ "$_owner_wt" = "$WORKTREE" ]; then _take=1
			elif lease_stale "$_lf"; then _take=1
			elif [ "$CANONICAL_TAKEOVER" = "1" ]; then _take=1
			fi
		fi
		if [ "$_take" = "1" ]; then
			{
				printf 'id=%s\n' "$AGENT_ID"
				printf 'repo=%s\n' "$REPO_ROOT"
				printf 'pid=%s\n' "$LEASE_PID"
				printf 'epoch=%s\n' "$_epoch"
				printf 'worktree=%s\n' "$WORKTREE"
				printf 'canonical=%s\n' "$_cp"
			} > "$_lf"
			CANONICAL_RESULT="${CANONICAL_RESULT}${_nm} ${_cp}
"
		fi
	done
	release_alloc_lock
}

# compute_canonical_deterministic: PURE preview of which canonical numbers WOULD
# be handed out (base + index per name), with no lease and no singleton check.
# Used only in --dry-run so the plan is complete for the wrappers to preview.
compute_canonical_deterministic() {
	CANONICAL_RESULT=""
	_idx=0
	for _nm in $(canonical_names); do
		_cp=$(( CANONICAL_BASE + _idx ))
		_idx=$(( _idx + 1 ))
		CANONICAL_RESULT="${CANONICAL_RESULT}${_nm} ${_cp}
"
	done
}

# print_canonical: emit one `canonical_port_<name>=<n>` line per held name.
print_canonical() {
	[ -n "$CANONICAL_RESULT" ] || return 0
	printf '%s' "$CANONICAL_RESULT" | while IFS=' ' read -r _nm _p; do
		[ -n "$_nm" ] || continue
		printf 'canonical_port_%s=%s\n' "$_nm" "$_p"
	done
}

# release_canonical_for_worktree: drop every canonical lease this worktree holds,
# handing each name back so another agent can take it.
release_canonical_for_worktree() {
	[ -d "$LEASES_DIR" ] || return 0
	acquire_alloc_lock
	for _lf in "$LEASES_DIR"/canonical-*.lease; do
		[ -f "$_lf" ] || continue
		_owner_wt="$(sed -n 's/^worktree=//p' "$_lf" 2>/dev/null | head -1)"
		if [ "$_owner_wt" = "$WORKTREE" ]; then
			rm -f "$_lf" 2>/dev/null || true
		fi
	done
	release_alloc_lock
}

# --- service isolation (items 5+6): --isolate docker|db, ENV-ONLY ------------
# Turn the advisory $IT2AGENT_NS prefix into concrete, opt-in service isolation
# by EXPORTING variables the project's own tooling already honors. This layer
# never invokes docker and never connects to Postgres — it only hands over
# names; the repo's compose files / migrations / connection code read them.
#
#   --isolate docker   (flag agent.isolate_docker): export
#                        COMPOSE_PROJECT_NAME=$IT2AGENT_NS so `docker compose`
#                        gets a per-agent project (isolated networks/volumes/
#                        containers) and stacks don't collide between agents.
#   --isolate db        (flag agent.isolate_db, default schema mode): export
#                        IT2AGENT_DB_SCHEMA=$IT2AGENT_NS plus
#                        PGOPTIONS='-c search_path=$IT2AGENT_NS' so the project's
#                        connection lands in a per-agent Postgres schema.
#   --isolate db=database: export IT2AGENT_DB_NAME=$IT2AGENT_NS instead (a
#                        per-agent database name rather than a schema).
#   --isolate namespace: REJECTED on macOS (parse-time error) — Linux
#                        netns/cgroups have no host-process equivalent on Darwin;
#                        the only real network-namespace isolation here is a
#                        container, i.e. --isolate docker.
#
# Each mode self-gates on its OWN flag (fail-safe OFF, bypassable with --no-gate
# / IT2AGENT_FORCE for tests). A requested mode whose flag is OFF emits nothing.
# The wrappers turn every emitted `env_<NAME>=<value>` line into an
# `export <NAME>=<value>` in the new session.

# parse_isolate: fold the accumulated ISOLATE_CSV into ISOLATE_DOCKER /
# ISOLATE_DB / DB_MODE. Rejects `namespace` and unknown tokens with a clear
# message. Pure; safe to call for every command so the rejection is consistent.
parse_isolate() {
	[ -n "$ISOLATE_CSV" ] || return 0
	_oldifs="$IFS"; IFS=','
	for _tok in $ISOLATE_CSV; do
		case "$_tok" in
			"") ;;
			docker) ISOLATE_DOCKER=1 ;;
			db|db=schema) ISOLATE_DB=1; DB_MODE="schema" ;;
			db=database) ISOLATE_DB=1; DB_MODE="database" ;;
			namespace|namespace=*)
				IFS="$_oldifs"
				die "--isolate namespace is not supported on macOS (host processes have no network namespaces); use --isolate docker for container-level isolation" ;;
			*)
				IFS="$_oldifs"
				die "--isolate: unknown mode '$_tok' (valid: docker, db, db=schema, db=database)" ;;
		esac
	done
	IFS="$_oldifs"
}

isolate_docker_gate_open() {
	[ "${IT2AGENT_FORCE:-}" = "1" ] && return 0
	[ "$NO_GATE" = "1" ] && return 0
	flag="$(find_flag 2>/dev/null)" || return 1
	"$flag" "$FLAG_KEY_ISOLATE_DOCKER" >/dev/null 2>&1
}

isolate_db_gate_open() {
	[ "${IT2AGENT_FORCE:-}" = "1" ] && return 0
	[ "$NO_GATE" = "1" ] && return 0
	flag="$(find_flag 2>/dev/null)" || return 1
	"$flag" "$FLAG_KEY_ISOLATE_DB" >/dev/null 2>&1
}

# print_isolate: emit the ENV-ONLY isolation exports for each REQUESTED mode
# whose flag gate is open, as `env_<NAME>=<value>` lines, plus a single
# `isolate=<modes>` summary of what was actually activated. NAMESPACE must
# already be set (compute_plan). No side effects: nothing is run or created.
print_isolate() {
	_active=""
	if [ "$ISOLATE_DOCKER" = "1" ] && isolate_docker_gate_open; then
		printf 'env_COMPOSE_PROJECT_NAME=%s\n' "$NAMESPACE"
		_active="${_active:+$_active,}docker"
	fi
	if [ "$ISOLATE_DB" = "1" ] && isolate_db_gate_open; then
		if [ "$DB_MODE" = "database" ]; then
			printf 'env_IT2AGENT_DB_NAME=%s\n' "$NAMESPACE"
			_active="${_active:+$_active,}db=database"
		else
			printf 'env_IT2AGENT_DB_SCHEMA=%s\n' "$NAMESPACE"
			printf 'env_PGOPTIONS=-c search_path=%s\n' "$NAMESPACE"
			_active="${_active:+$_active,}db=schema"
		fi
	fi
	[ -n "$_active" ] && printf 'isolate=%s\n' "$_active"
	return 0
}

# --- git plan runner ---------------------------------------------------------
# run_git: in dry-run print the command; otherwise execute it (git chatter to
# stderr so stdout stays machine-parseable).
run_git() {
	if [ "$DRYRUN" = "1" ]; then
		printf 'would-run: git'
		for a in "$@"; do printf ' %s' "$a"; done
		printf '\n'
		return 0
	fi
	git "$@" >&2
}

# --- create ------------------------------------------------------------------
cmd_create() {
	compute_plan

	# Claim free port(s) under the allocation lease only when actually creating
	# (not in dry-run, so the printed plan stays deterministic and reproducible
	# on any machine). --no-probe forces the deterministic port(s) as-is with no
	# lease (back-compat: the value is exactly the pure plan's). --ports adds one
	# leased port per name; without it there is exactly one port, as in #13.
	if [ "$DRYRUN" != "1" ] && [ "$NO_PROBE" != "1" ]; then
		lease_all_ports
	else
		compute_ports_deterministic
	fi

	# Emit the allocation FIRST so callers can capture values regardless of what
	# the git layer prints afterwards.
	print_plan
	print_extra_ports

	# Canonical port (item 4): self-gated on agent.canonical_port. When ON, also
	# try to hold the project-normal port for each name and export it. Only one
	# agent per repo holds each name at a time (singleton).
	if canonical_gate_open; then
		if [ "$DRYRUN" = "1" ]; then
			compute_canonical_deterministic
			print_canonical
			printf 'would-run: acquire canonical singleton lease(s) under %s\n' "$LEASES_DIR"
		else
			acquire_all_canonical
			print_canonical
		fi
	fi

	# Service isolation (items 5+6): ENV-ONLY, each mode self-gated on its own
	# flag. Emits env_<NAME>=<value> lines the wrappers export. Works the same in
	# --dry-run (there are no side effects to withhold — nothing is run/created).
	print_isolate

	if [ "$DRYRUN" = "1" ]; then
		printf 'would-run: mkdir -p %s\n' "$(dirname "$WORKTREE")"
		[ "$NO_PROBE" != "1" ] && printf 'would-run: lease port(s) under %s (advancing on conflict)\n' "$LEASES_DIR"
	else
		mkdir -p "$(dirname "$WORKTREE")" || die "cannot create worktree parent: $(dirname "$WORKTREE")"
	fi

	# Idempotent: a worktree already registered at this path -> reuse it.
	if [ "$DRYRUN" != "1" ] && git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null \
		| grep -qxF "worktree $WORKTREE"; then
		warn "reusing existing worktree at $WORKTREE"
		return 0
	fi
	if [ -e "$WORKTREE" ] && [ "$DRYRUN" != "1" ]; then
		# Path exists but is not a registered worktree: refuse to clobber.
		die "worktree path already exists and is not a git worktree: $WORKTREE"
	fi

	# Does the branch already exist? If so, add a worktree ON it; else create it.
	if [ "$DRYRUN" != "1" ] \
		&& git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
		warn "branch $BRANCH already exists; adding a worktree on it"
		run_git -C "$REPO_ROOT" worktree add "$WORKTREE" "$BRANCH"
	else
		# New branch off current HEAD. A dirty main checkout does NOT block this:
		# `git worktree add -b` branches from HEAD (committed state), leaving the
		# spawner's uncommitted changes untouched in the main worktree.
		run_git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE"
	fi
}

# --- cleanup -----------------------------------------------------------------
detect_base() {
	# Default merge base for "is this branch merged" checks. Prefer the remote
	# HEAD, then a local main/master, then the repo's current branch.
	b="$(git -C "$REPO_ROOT" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
	if [ -n "$b" ] && git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$b"; then
		printf '%s' "$b"; return 0
	fi
	for cand in main master; do
		if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$cand"; then
			printf '%s' "$cand"; return 0
		fi
	done
	git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null
}

cmd_cleanup() {
	compute_plan
	print_plan

	base="$BASE_REF"
	[ -n "$base" ] || base="$(detect_base)"
	[ -n "$base" ] || die "cannot determine a base branch for the merged check (pass --base)"
	printf 'base=%s\n' "$base"

	if [ "$DRYRUN" = "1" ]; then
		printf 'would-run: git -C %s status --porcelain   (in worktree %s)\n' "$WORKTREE" "$WORKTREE"
		printf 'would-run: git -C %s branch --merged %s   (checking %s)\n' "$REPO_ROOT" "$base" "$BRANCH"
		printf 'would-run: git -C %s worktree remove %s\n' "$REPO_ROOT" "$WORKTREE"
		printf 'would-run: git -C %s branch -d %s\n' "$REPO_ROOT" "$BRANCH"
		printf 'would-run: git -C %s worktree prune\n' "$REPO_ROOT"
		printf 'would-run: release port lease(s) + canonical lease(s) for %s under %s\n' "$WORKTREE" "$LEASES_DIR"
		return 0
	fi

	# The worktree may already be gone; the branch may still linger.
	wt_registered=0
	if git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null \
		| grep -qxF "worktree $WORKTREE"; then
		wt_registered=1
	fi
	branch_exists=0
	if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
		branch_exists=1
	fi

	if [ "$wt_registered" = "0" ] && [ "$branch_exists" = "0" ]; then
		warn "nothing to clean: no worktree at $WORKTREE and no branch $BRANCH"
		git -C "$REPO_ROOT" worktree prune >&2 2>/dev/null || true
		# Still release any lingering lease so a removed worktree never leaks one.
		release_leases_for_worktree
		release_canonical_for_worktree
		return 0
	fi

	# SAFETY 1: refuse a dirty working tree (uncommitted or untracked changes).
	if [ "$wt_registered" = "1" ] && [ -d "$WORKTREE" ]; then
		dirty="$(git -C "$WORKTREE" status --porcelain 2>/dev/null)"
		if [ -n "$dirty" ]; then
			if [ "$FORCE" = "1" ]; then
				warn "worktree $WORKTREE is DIRTY; removing anyway (--force)"
			else
				warn "refusing to remove: worktree $WORKTREE has uncommitted/untracked changes"
				warn "commit or stash them, or pass --force to discard. Nothing was removed."
				return 1
			fi
		fi
	fi

	# SAFETY 2: refuse an unmerged branch (commits not reachable from base).
	if [ "$branch_exists" = "1" ]; then
		merged=0
		if git -C "$REPO_ROOT" branch --merged "$base" --format '%(refname:short)' 2>/dev/null \
			| grep -qxF "$BRANCH"; then
			merged=1
		fi
		if [ "$merged" = "0" ]; then
			if [ "$FORCE" = "1" ]; then
				warn "branch $BRANCH is NOT merged into $base; removing anyway (--force)"
			else
				ahead="$(git -C "$REPO_ROOT" rev-list --count "$base..$BRANCH" 2>/dev/null || echo '?')"
				warn "refusing to remove: branch $BRANCH has $ahead commit(s) not merged into $base"
				warn "merge it first, or pass --force to destroy the work. Nothing was removed."
				return 1
			fi
		fi
	fi

	# Safe (or forced): remove the worktree, then delete the branch, then prune.
	if [ "$wt_registered" = "1" ]; then
		if [ "$FORCE" = "1" ]; then
			git -C "$REPO_ROOT" worktree remove --force "$WORKTREE" >&2
		else
			git -C "$REPO_ROOT" worktree remove "$WORKTREE" >&2
		fi
	fi
	if [ "$branch_exists" = "1" ]; then
		if [ "$FORCE" = "1" ]; then
			git -C "$REPO_ROOT" branch -D "$BRANCH" >&2
		else
			git -C "$REPO_ROOT" branch -d "$BRANCH" >&2
		fi
	fi
	git -C "$REPO_ROOT" worktree prune >&2 2>/dev/null || true
	# Release the port lease(s) this worktree held so the port returns to the pool,
	# plus any canonical singleton it held so another agent can take it.
	release_leases_for_worktree
	release_canonical_for_worktree
	warn "removed worktree $WORKTREE and branch $BRANCH"
}

# --- env ---------------------------------------------------------------------
# Print eval-able export lines for the spawned session. Pure (no git, no gate,
# no lease). With --ports each name is exported as IT2AGENT_PORT_<UPPER>, and the
# first is also the bare IT2AGENT_PORT (back-compat). Canonical ports are stateful
# (singleton lease) so they are NOT part of the pure env — they come from create.
cmd_env() {
	compute_plan
	compute_ports_deterministic
	printf 'export IT2AGENT_PORT=%s\n' "$PORT"
	if [ -n "$LEASED_PORTS" ]; then
		printf '%s' "$LEASED_PORTS" | while IFS=' ' read -r _nm _p; do
			[ -n "$_nm" ] || continue
			printf 'export IT2AGENT_PORT_%s=%s\n' "$(portkey "$_nm")" "$_p"
		done
	fi
	printf 'export IT2AGENT_NS=%s\n' "$NAMESPACE"
	printf 'export IT2AGENT_WORKTREE=%s\n' "$WORKTREE"
	printf 'export IT2AGENT_BRANCH=%s\n' "$BRANCH"
}

# --- canonical (item 4 explicit management) ----------------------------------
# Acquire (default) or --release the per-(repo, port-name) canonical singleton
# for this agent, independent of create. Self-gates on agent.canonical_port.
cmd_canonical() {
	compute_plan
	if [ "$RELEASE" = "1" ]; then
		release_canonical_for_worktree
		printf 'canonical_released=%s\n' "$WORKTREE"
		return 0
	fi
	acquire_all_canonical
	print_canonical
}

# --- ls / status (read-only observability reporter) --------------------------
# Composes what already exists — `git worktree list --porcelain` (filtered to the
# it2agent/<role>-<id>-<hash> branch scheme), the `.leases/` dir, and per-worktree
# `git status --porcelain` — into a table (`ls`) or JSON (`status`/`--json`). It
# is a PURE reader: it allocates no port, creates no worktree, and never touches
# settings or leases. Stale entries (worktree gone, or a lease whose owner pid is
# dead — the same reclaim rule the allocator uses in lease_stale) are only
# REPORTED, never deleted.

# leases_for_worktree <worktree-path>: scan LEASES_DIR (read-only) for every lease
# whose worktree matches, and set:
#   _WT_PORTS = comma-joined dynamic port numbers (all N of a --ports agent)
#   _WT_CANON = comma-joined canonical port numbers this worktree holds
#   _WT_PID   = an owner pid observed on a dynamic lease (0 if none/untracked)
# Dynamic leases are `<port>.lease`; canonical leases are `canonical-<name>.lease`.
leases_for_worktree() {
	_WT_PORTS=""; _WT_CANON=""; _WT_PID=0
	[ -d "$LEASES_DIR" ] || return 0
	for lf in "$LEASES_DIR"/*.lease; do
		[ -f "$lf" ] || continue
		l_wt="$(sed -n 's/^worktree=//p' "$lf" 2>/dev/null | head -1)"
		[ "$l_wt" = "$1" ] || continue
		base="$(basename "$lf" .lease)"
		case "$base" in
			canonical-*)
				l_cp="$(sed -n 's/^canonical=//p' "$lf" 2>/dev/null | head -1)"
				[ -n "$l_cp" ] && _WT_CANON="${_WT_CANON:+$_WT_CANON,}$l_cp"
				;;
			*)
				_WT_PORTS="${_WT_PORTS:+$_WT_PORTS,}$base"
				l_pid="$(sed -n 's/^pid=//p' "$lf" 2>/dev/null | head -1)"
				[ -n "$l_pid" ] && _WT_PID="$l_pid"
				;;
		esac
	done
}

# emit_record <worktree-path> <branch>: print one REC_SEP-separated record
#   branch  worktree  port  ports  canonical  changes  stale  reason
# port is the first dynamic port (back-compat; empty when unleased); ports is the
# comma list of ALL dynamic ports; canonical is the comma list of canonical ports
# held; changes is empty when the worktree dir is gone; stale is 0/1; reason is
# "" / worktree-gone / owner-dead.
emit_record() {
	_wt="$1"; _br="$2"
	leases_for_worktree "$_wt"
	_ports="$_WT_PORTS"; _canon="$_WT_CANON"; _pid="$_WT_PID"
	_port="${_ports%%,*}"   # first dynamic port (empty when none)
	_stale=0; _reason=""; _changes=""
	if [ ! -d "$_wt" ]; then
		_stale=1; _reason="worktree-gone"
	else
		_changes="$(git -C "$_wt" status --porcelain 2>/dev/null | wc -l | tr -d ' ')"
		if [ "$_pid" != "0" ] && ! pid_alive "$_pid"; then
			_stale=1; _reason="owner-dead"
		fi
	fi
	printf '%s%s%s%s%s%s%s%s%s%s%s%s%s%s%s\n' \
		"$_br" "$REC_SEP" "$_wt" "$REC_SEP" "$_port" "$REC_SEP" \
		"$_ports" "$REC_SEP" "$_canon" "$REC_SEP" \
		"$_changes" "$REC_SEP" "$_stale" "$REC_SEP" "$_reason"
}

# collect_records: emit one record line per agent worktree of REPO_ROOT. Filters
# `git worktree list --porcelain` to branches under the it2agent/ scheme. A
# trailing blank line is appended so the final porcelain block always flushes.
collect_records() {
	{ git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null; printf '\n'; } | {
		wt=""; br=""
		while IFS= read -r line; do
			case "$line" in
				"worktree "*) wt="${line#worktree }" ;;
				"branch refs/heads/"*) br="${line#branch refs/heads/}" ;;
				"")
					case "$br" in
						it2agent/*) [ -n "$wt" ] && emit_record "$wt" "$br" ;;
					esac
					wt=""; br=""
					;;
			esac
		done
	}
}

# --- JSON formatting (pure, careful escaping; no python dependency) ----------
json_escape() {
	printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}
jstr() { printf '"%s"' "$(json_escape "$1")"; }
jstrn() { if [ -z "$1" ]; then printf 'null'; else printf '"%s"' "$(json_escape "$1")"; fi; }
jnum() { if [ -z "$1" ]; then printf 'null'; else printf '%s' "$1"; fi; }
jbool() { if [ "$1" = "1" ]; then printf 'true'; else printf 'false'; fi; }

# jnum_array <comma-list>: render a comma list of numbers as a JSON array. Empty
# input -> []. No quoting: the members are always integers.
jnum_array() {
	printf '['
	_f=1; _old="$IFS"; IFS=','
	for _v in $1; do
		[ "$_f" = "1" ] || printf ','
		_f=0; printf '%s' "$_v"
	done
	IFS="$_old"
	printf ']'
}

render_json() {
	printf '['
	first=1
	printf '%s\n' "$RECORDS" | while IFS="$REC_SEP" read -r br wt port ports canon changes stale reason; do
		[ "$first" = "1" ] || printf ','
		first=0
		if [ -z "$changes" ]; then clean=null
		elif [ "$changes" = "0" ]; then clean=true
		else clean=false; fi
		printf '{"branch":%s,"worktree":%s,"port":%s,"ports":%s,"canonical":%s,"changes":%s,"clean":%s,"stale":%s,"stale_reason":%s}' \
			"$(jstr "$br")" "$(jstr "$wt")" "$(jnum "$port")" "$(jnum_array "$ports")" \
			"$(jnum_array "$canon")" "$(jnum "$changes")" \
			"$clean" "$(jbool "$stale")" "$(jstrn "$reason")"
	done
	printf ']\n'
}

render_table() {
	printf '%-42s  %-13s  %-8s  %-13s  %-16s  %s\n' BRANCH PORTS CANON STATUS STALE WORKTREE
	printf '%s\n' "$RECORDS" | while IFS="$REC_SEP" read -r br wt port ports canon changes stale reason; do
		if [ "$reason" = "worktree-gone" ]; then st="gone"
		elif [ -z "$changes" ]; then st="-"
		elif [ "$changes" = "0" ]; then st="clean"
		elif [ "$changes" = "1" ]; then st="1 change"
		else st="$changes changes"; fi
		smark="-"
		[ "$stale" = "1" ] && smark="STALE ($reason)"
		printf '%-42s  %-13s  %-8s  %-13s  %-16s  %s\n' "$br" "${ports:--}" "${canon:--}" "$st" "$smark" "$wt"
	done
}

# cmd_report: the ls/status entry point. JSON=1 emits machine-readable JSON;
# otherwise a human table. Read-only; never gates (like plan/env).
cmd_report() {
	compute_wt_root
	RECORDS="$(collect_records)"
	if [ -z "$RECORDS" ]; then
		if [ "$JSON" = "1" ]; then
			printf '[]\n'
		else
			warn "no agent (it2agent/…) worktrees for $REPO_ROOT"
		fi
		return 0
	fi
	if [ "$JSON" = "1" ]; then
		render_json
	else
		render_table
	fi
}

usage() {
	cat <<EOF
$PROG — per-agent git-worktree + \$IT2AGENT_PORT / \$IT2AGENT_NS isolation.

Usage:
  $PROG <command> [options]

Commands:
  plan       Print the derived allocation (pure, no side effects, no gate):
             branch, worktree path, port, namespace, hash, repo.
  env        Print eval-able export lines (IT2AGENT_PORT / _NS / _WORKTREE /
             _BRANCH). Pure, no side effects, no gate.
  create     Create the git worktree on the derived branch (gated). Prints the
             allocation on stdout. Idempotent; --dry-run prints the git plan.
  cleanup    Remove an agent's worktree + branch IF SAFE (gated): refuses a
             dirty working tree and an unmerged branch. --force overrides.
  ls         List this repo's agent worktrees as a human table (read-only, no
             gate): branch, leased port, git-status summary, STALE marker, and
             worktree path. Composes git worktree list + .leases + git status;
             allocates nothing and never deletes/reclaims.
  status     Same data as \`ls\`; add --json for a machine-readable array (stable
             keys: branch, worktree, port, ports, canonical, changes, clean,
             stale, stale_reason) for the janitor / daemon / MCP to consume.
  canonical  Acquire (or --release) the per-(repo, port-name) CANONICAL singleton
             for this agent (gated on $FLAG_KEY_CANONICAL). Prints
             canonical_port_<name>=<n> for each name held.
  -h,--help  Show this help.

Common options:
  --repo <dir>       Repo to operate on (default: \$PWD). Resolved to its git
                     top-level.
  --id <id>          Agent id (REQUIRED). Anchors the deterministic hash.
  --role <role>      Agent role (feeds the human-readable slug + namespace).
  --task <task>      Agent task (informational; not part of the hash).
  --base-port <n>    Base of the port range (default: $DEFAULT_BASE_PORT).
  --span <n>         Size of the port range (default: $DEFAULT_SPAN).
                     Deterministic port = base + (hash % span).
  --ports <a,b,c>    Allocate one dynamic port PER NAME, each exported as
                     IT2AGENT_PORT_<UPPER> (first is also the bare IT2AGENT_PORT,
                     back-compat). Each name folds into its hash so they don't
                     collide. Without --ports there is exactly one port, as in #13.
  --isolate <list>   Opt-in service isolation, ENV-ONLY (comma list, repeatable):
                       docker       export COMPOSE_PROJECT_NAME=\$IT2AGENT_NS
                                    (gated on $FLAG_KEY_ISOLATE_DOCKER).
                       db|db=schema export IT2AGENT_DB_SCHEMA=\$IT2AGENT_NS plus
                                    PGOPTIONS='-c search_path=\$IT2AGENT_NS'
                                    (gated on $FLAG_KEY_ISOLATE_DB).
                       db=database  export IT2AGENT_DB_NAME=\$IT2AGENT_NS instead.
                       namespace    REJECTED on macOS (use docker).
                     We only EXPORT names the project's own compose/DB tooling
                     reads; we never run docker or connect to Postgres. Each
                     mode emits nothing unless its flag is ON (or --no-gate).

create options:
  --dry-run          Print the git commands + allocation; execute nothing.
  --no-probe         Skip free-port probing AND leasing; use the deterministic
                     port as-is (back-compat; identical to the pure plan).
  --lease-pid <n>    Bind the port lease to a durable process pid so it is
                     reclaimed when that process dies (default 0 = the lease is
                     tied to the worktree only).
  --canonical-port <base>
                     Base for the canonical number handed out per name (default
                     $DEFAULT_CANONICAL_BASE; first name -> base, second -> base+1, …).
  --canonical-takeover
                     When acquiring a canonical name already held by a live agent,
                     hand it over instead of leaving it (default: leave it).
  --no-gate          Bypass the feature-flag gate (local testing).

canonical options:
  --ports <a,b,c>    Names to hold the canonical singleton for (default: web).
  --canonical-port <base>   Canonical base (see above).
  --canonical-takeover      Force a handover from the current live holder.
  --release          Hand back every canonical name this agent holds.
  --no-gate          Bypass the $FLAG_KEY_CANONICAL gate (local testing).

cleanup options:
  --base <ref>       Branch to test "merged into" against (default: auto-detect
                     origin/HEAD, then main/master, then current branch).
  --force            Override the dirty/unmerged safety refusals (DESTRUCTIVE).
  --dry-run          Print the git commands; execute nothing.
  --no-gate          Bypass the feature-flag gate (local testing).

ls / status options:
  --json             Emit a JSON array instead of a table (status default is a
                     table too; --json switches either command to JSON).

Environment:
  IT2AGENT_WORKTREE_ROOT   Override the parent dir for all worktrees.
  IT2AGENT_FORCE=1         Bypass the feature-flag gate (like --no-gate).

Gating: create/cleanup emit/act only when "$FLAG_KEY" is ON
(checked via it2agent-flag). When OFF they no-op and exit 0 (fail-safe).
plan/env are pure and never gate.

Isolation model, port scheme, and cleanup safety: it2agent/spawn/WORKTREE.md
EOF
}

# --- parse -------------------------------------------------------------------
[ $# -ge 1 ] || { usage >&2; die "no command given"; }

CMD="$1"; shift
case "$CMD" in
	-h|--help|help) usage; exit 0 ;;
	plan|env|create|cleanup|ls|status|canonical) ;;
	*) die "unknown command: $CMD (try --help)" ;;
esac

REPO_ARG=""
AGENT_ID=""
ROLE=""
TASK=""
BASE_PORT="$DEFAULT_BASE_PORT"
SPAN="$DEFAULT_SPAN"
DRYRUN=0
NO_GATE=0
NO_PROBE=0
FORCE=0
BASE_REF=""
LEASE_PID=0
JSON=0
PORTS_CSV=""
CANONICAL_BASE="$DEFAULT_CANONICAL_BASE"
CANONICAL_TAKEOVER=0
RELEASE=0
ISOLATE_CSV=""       # accumulated --isolate list(s); parsed by parse_isolate
ISOLATE_DOCKER=0
ISOLATE_DB=0
DB_MODE="schema"     # schema (default) | database, set by --isolate db=...

[ "${IT2AGENT_FORCE:-}" = "1" ] && NO_GATE=1

while [ $# -gt 0 ]; do
	case "$1" in
		--repo) [ $# -ge 2 ] || die "--repo requires a <dir>"; REPO_ARG="$2"; shift 2 ;;
		--repo=*) REPO_ARG="${1#--repo=}"; shift ;;
		--id) [ $# -ge 2 ] || die "--id requires an <id>"; AGENT_ID="$2"; shift 2 ;;
		--id=*) AGENT_ID="${1#--id=}"; shift ;;
		--role) [ $# -ge 2 ] || die "--role requires a <role>"; ROLE="$2"; shift 2 ;;
		--role=*) ROLE="${1#--role=}"; shift ;;
		--task) [ $# -ge 2 ] || die "--task requires a <task>"; TASK="$2"; shift 2 ;;
		--task=*) TASK="${1#--task=}"; shift ;;
		--base-port) [ $# -ge 2 ] || die "--base-port requires a value"; BASE_PORT="$2"; shift 2 ;;
		--base-port=*) BASE_PORT="${1#--base-port=}"; shift ;;
		--span) [ $# -ge 2 ] || die "--span requires a value"; SPAN="$2"; shift 2 ;;
		--span=*) SPAN="${1#--span=}"; shift ;;
		--base) [ $# -ge 2 ] || die "--base requires a <ref>"; BASE_REF="$2"; shift 2 ;;
		--base=*) BASE_REF="${1#--base=}"; shift ;;
		--ports) [ $# -ge 2 ] || die "--ports requires a comma-separated list"; PORTS_CSV="$2"; shift 2 ;;
		--ports=*) PORTS_CSV="${1#--ports=}"; shift ;;
		--isolate) [ $# -ge 2 ] || die "--isolate requires a list (docker, db, db=schema, db=database)"; ISOLATE_CSV="${ISOLATE_CSV:+$ISOLATE_CSV,}$2"; shift 2 ;;
		--isolate=*) ISOLATE_CSV="${ISOLATE_CSV:+$ISOLATE_CSV,}${1#--isolate=}"; shift ;;
		--canonical-port) [ $# -ge 2 ] || die "--canonical-port requires a value"; CANONICAL_BASE="$2"; shift 2 ;;
		--canonical-port=*) CANONICAL_BASE="${1#--canonical-port=}"; shift ;;
		--canonical-takeover) CANONICAL_TAKEOVER=1; shift ;;
		--release) RELEASE=1; shift ;;
		--dry-run) DRYRUN=1; shift ;;
		--no-gate) NO_GATE=1; shift ;;
		--no-probe) NO_PROBE=1; shift ;;
		--json) JSON=1; shift ;;
		--lease-pid) [ $# -ge 2 ] || die "--lease-pid requires a value"; LEASE_PID="$2"; shift 2 ;;
		--lease-pid=*) LEASE_PID="${1#--lease-pid=}"; shift ;;
		--force) FORCE=1; shift ;;
		-h|--help) usage; exit 0 ;;
		--) shift; break ;;
		-*) die "unknown option: $1 (try --help)" ;;
		*) die "unexpected argument: $1 (try --help)" ;;
	esac
done

is_uint "$LEASE_PID" || die "--lease-pid must be a non-negative integer"
is_uint "$CANONICAL_BASE" || die "--canonical-port must be a non-negative integer"
# Validate/normalize --isolate up front so `namespace` (and typos) are rejected
# for every command, not just create.
parse_isolate

resolve_repo "$REPO_ARG"

case "$CMD" in
	plan)
		compute_plan
		compute_ports_deterministic
		print_plan
		print_extra_ports
		;;
	env)
		cmd_env
		;;
	ls|status)
		cmd_report
		;;
	canonical)
		if ! canonical_gate_open; then
			warn "gate closed ($FLAG_KEY_CANONICAL is OFF); canonical port not touched"
			exit 0
		fi
		cmd_canonical
		;;
	create)
		if ! gate_open; then
			warn "gate closed ($FLAG_KEY is OFF); no worktree created"
			exit 0
		fi
		cmd_create
		;;
	cleanup)
		if ! gate_open; then
			warn "gate closed ($FLAG_KEY is OFF); no cleanup performed"
			exit 0
		fi
		cmd_cleanup
		;;
esac
