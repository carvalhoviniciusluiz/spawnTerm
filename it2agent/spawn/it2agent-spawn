#!/usr/bin/env sh
# it2agent-spawn — open a new iTerm2 tab running a command and stamp the new
# agent's identity (role/task/status/color/badge) from birth.
#
# it2agent Tier 0.4 (#10). scope:external-tooling — this is glue that drives
# iTerm2 via its AppleScript API + shells out to `it2agent-emit`; it never
# modifies iTerm2 source and never re-implements escape codes itself.
#
# This is a self-contained *reference* spawn wrapper. It demonstrates the two
# operator wins from issue #3 and the emit-on-spawn integration so the real
# `spawn-tl` flow can drop these calls in (see it2agent/spawn/README.md):
#
#   1. cwd inheritance (the quick win, no daemon):
#        default   -> the new tab inherits the spawner's $PWD
#        --dir DIR -> open in a specific folder
#        --home    -> open in the user's home directory
#
#   2. identity stamping on spawn: after the tab is created we run, *in the new
#      session*, the merged it2agent-emit for each facet, so the tab is
#      tagged/colored/badged immediately:
#        it2agent-emit role   <role>
#        it2agent-emit task   <task>
#        it2agent-emit status <status>      (busy by default)
#        it2agent-emit color  <status>      (lifecycle -> colorblind-safe hex)
#        it2agent-emit badge                (default: role · task)
#      These write the DOT-FREE user vars agent_role / agent_task / agent_status
#      (iTerm2 forbids '.' in a SetUserVar key), matching it2agent-emit (#7/#24).
#
# Feature-flag gating: we do NOT gate here. Spawning a tab is core and always
# happens. The identity emits are plain calls to it2agent-emit, which
# SELF-GATES on `agent.status_board` (via it2agent-flag): when the flag is
# OFF the emit calls produce nothing and exit 0, so the tab simply isn't tagged.
# This is the simplest correct approach (one gate, in one place). To bypass the
# gate for local testing, pass --no-gate (forwarded to every emit call) or set
# IT2AGENT_FORCE=1 (forwarded as --no-gate into the new session).
#
# Opening a tab with a working dir + running a command on stock iTerm2 (no Tier
# 1 daemon) is done with osascript against iTerm2's scripting model. The boot
# script is launched DIRECTLY as the new session's `command` (create tab with
# default profile command "..."), never typed via `write text` — that typing was
# the source of the #74 delivery race. The AppleScript is built as a here-doc
# below.
#
# No external deps beyond osascript (macOS built-in) and it2agent-emit.
set -eu

PROG="it2agent-spawn"

# --- locate the merged it2agent-emit ----------------------------------------
# Prefer the sibling copy shipped next to this script; fall back to PATH. We
# resolve to an ABSOLUTE path because the emit call runs in the NEW session,
# whose PATH/cwd we do not control.
script_dir() {
	# POSIX-ish dirname of $0, resolved to an absolute path.
	d="$(dirname "$0")"
	(cd "$d" 2>/dev/null && pwd)
}

find_emit() {
	sd="$(script_dir)"
	if [ -n "$sd" ] && [ -x "$sd/../emit/it2agent-emit" ]; then
		emit_dir="$(cd "$sd/../emit" && pwd)"
		printf '%s/it2agent-emit' "$emit_dir"
		return 0
	fi
	if command -v it2agent-emit >/dev/null 2>&1; then
		command -v it2agent-emit
		return 0
	fi
	return 1
}

# Locate the sibling it2agent-worktree helper (#13), else fall back to PATH.
find_worktree() {
	sd="$(script_dir)"
	if [ -n "$sd" ] && [ -x "$sd/it2agent-worktree" ]; then
		printf '%s/it2agent-worktree' "$sd"
		return 0
	fi
	if command -v it2agent-worktree >/dev/null 2>&1; then
		command -v it2agent-worktree
		return 0
	fi
	return 1
}

# Locate the sibling it2agent-flag helper (#11), for the isolation gate.
find_flag() {
	sd="$(script_dir)"
	if [ -n "$sd" ] && [ -x "$sd/../flags/it2agent-flag" ]; then
		fd="$(cd "$sd/../flags" && pwd)"
		printf '%s/it2agent-flag' "$fd"
		return 0
	fi
	if command -v it2agent-flag >/dev/null 2>&1; then
		command -v it2agent-flag
		return 0
	fi
	return 1
}

die() {
	printf '%s: %s\n' "$PROG" "$1" >&2
	exit 2
}

usage() {
	cat <<EOF
$PROG — open a new iTerm2 tab, cd into a directory, and stamp the new
agent's identity via it2agent-emit, then run a command.

Usage:
  $PROG [options] [--] <command> [args...]

Working directory (issue #3 quick win — no daemon):
  (default)        Inherit the spawner's \$PWD.
  --dir <path>     Open the tab in a specific directory.
  --home           Open the tab in the user's home directory (\$HOME).

Identity (stamped in the new session via it2agent-emit):
  --role <role>    agent_role   (also feeds the default badge).
  --task <task>    agent_task   (also feeds the default badge).
  --status <s>     agent_status + tab color. One of: busy, blocked, done, idle.
                   Default: busy. The color is derived from the status.

Worktree + port/namespace isolation (issue #13 — gated OFF by default):
  --id <id>        Agent id anchoring the deterministic isolation allocation.
                   Defaults to "<role>-<task>" (or "<role>"/"<task>") when
                   isolation is ON and --id is omitted.
  --base-port <n>  Base of the per-agent port range (default 41000).
  --ports <a,b,c>  Allocate one dynamic port per name, exported as
                   IT2AGENT_PORT_<UPPER> (first is also the bare IT2AGENT_PORT).
                   Without it there is exactly one port, as in #13.
  --isolate <list> Opt-in, ENV-ONLY service isolation (comma list). "docker"
                   exports COMPOSE_PROJECT_NAME=\$IT2AGENT_NS (flag
                   agent.isolate_docker); "db"/"db=schema" exports
                   IT2AGENT_DB_SCHEMA + PGOPTIONS search_path, "db=database"
                   exports IT2AGENT_DB_NAME (flag agent.isolate_db). "namespace"
                   is rejected on macOS. Each mode emits nothing unless its own
                   flag is ON. We only export names the project's compose/DB
                   tooling reads — we never run docker or connect to Postgres.
  --canonical-port <base>
                   Base for the canonical (project-normal) port handed to the
                   holder when the "agent.canonical_port" flag is ON (default 3000).
  --canonical-takeover
                   Take a canonical name already held by a live agent.
  --no-probe       Skip free-port probing; use the deterministic port as-is.
  --force-isolation
                   Force worktree/port isolation ON even when the
                   "agent.worktree_isolation" flag is OFF (explicit opt-in for
                   local testing). Distinct from --no-gate, which never enables
                   isolation.
  When the flag "agent.worktree_isolation" is ON, the new tab opens in a
  per-agent git WORKTREE on its own branch (not plain \$PWD), and the session
  exports \$IT2AGENT_PORT / \$IT2AGENT_NS / \$IT2AGENT_WORKTREE /
  \$IT2AGENT_BRANCH before the command runs. When OFF, spawn behaves exactly
  as #10 (plain cwd inheritance, no worktree, no port). See WORKTREE.md.

Capability guide:
  (default)        Inject a 1-line header into the new session pointing at the
                   it2agent capability guide (run: it2agent help).
  --no-guide       Do not inject the guide header.

Other:
  --no-gate        Forward --no-gate to every emit call (local testing). Does
                   NOT enable worktree isolation — use --force-isolation for that.
  --dry-run        Print the resolved cwd, the isolation plan (if ON), the emit
                   calls, the command, and the AppleScript that WOULD run —
                   execute nothing.
  -h, --help       Show this help.

Environment:
  IT2AGENT_SPAWN_DRYRUN=1   Same as --dry-run.
  IT2AGENT_FORCE=1          Forwarded as --no-gate into the emit calls. Does NOT
                             enable worktree isolation.
  IT2AGENT_FORCE_ISOLATION=1  Same as --force-isolation.

Gating: the identity emits self-gate on the feature flag
"agent.status_board" (via it2agent-emit -> it2agent-flag). Worktree/port
isolation gates on "agent.worktree_isolation" (checked here via
it2agent-flag). When both are OFF the tab still opens; it just isn't
tagged/colored/badged and inherits the spawner's \$PWD. Spawning is core and
never gated.

Examples:
  $PROG --role worker --task "build #10" -- claude --dangerously-skip-permissions
  $PROG --dir ~/proj/api --role reviewer --status idle -- \$SHELL -l
  $PROG --id 13 --role worker --task "isolate" -- claude   # per-agent worktree+port
EOF
}

# --- parse options ------------------------------------------------------------
DIR=""          # empty => inherit \$PWD
USE_HOME=0
ROLE=""
TASK=""
STATUS="busy"
AGENT_ID=""
BASE_PORT=""
PORTS=""            # --ports web,db,cache (empty => single port, = #13)
ISOLATE=""          # --isolate docker,db (empty => no service isolation)
CANONICAL_PORT=""   # --canonical-port <base> (passthrough to the helper)
CANONICAL_TAKEOVER=0
NO_PROBE=0
NO_GATE=0
NO_GUIDE=0
FORCE_ISOLATION=0
DRYRUN="${IT2AGENT_SPAWN_DRYRUN:-0}"
[ "$DRYRUN" = "1" ] || DRYRUN=0

# IT2AGENT_FORCE=1 in the spawner's env means "bypass the emit gate": forward it.
# NOTE (bug P2 fix): this bypasses ONLY the identity-emit gate. It does NOT turn
# on worktree isolation — that is opt-in via the agent.worktree_isolation flag or
# the explicit --force-isolation / IT2AGENT_FORCE_ISOLATION=1.
if [ "${IT2AGENT_FORCE:-}" = "1" ]; then
	NO_GATE=1
fi
if [ "${IT2AGENT_FORCE_ISOLATION:-}" = "1" ]; then
	FORCE_ISOLATION=1
fi

while [ $# -gt 0 ]; do
	case "$1" in
		--dir)
			[ $# -ge 2 ] || die "--dir requires a <path> argument"
			DIR="$2"; shift 2 ;;
		--dir=*)
			DIR="${1#--dir=}"; shift ;;
		--home)
			USE_HOME=1; shift ;;
		--role)
			[ $# -ge 2 ] || die "--role requires a <role> argument"
			ROLE="$2"; shift 2 ;;
		--role=*)
			ROLE="${1#--role=}"; shift ;;
		--task)
			[ $# -ge 2 ] || die "--task requires a <task> argument"
			TASK="$2"; shift 2 ;;
		--task=*)
			TASK="${1#--task=}"; shift ;;
		--status)
			[ $# -ge 2 ] || die "--status requires a <status> argument"
			STATUS="$2"; shift 2 ;;
		--status=*)
			STATUS="${1#--status=}"; shift ;;
		--id)
			[ $# -ge 2 ] || die "--id requires an <id> argument"
			AGENT_ID="$2"; shift 2 ;;
		--id=*)
			AGENT_ID="${1#--id=}"; shift ;;
		--base-port)
			[ $# -ge 2 ] || die "--base-port requires a value"
			BASE_PORT="$2"; shift 2 ;;
		--base-port=*)
			BASE_PORT="${1#--base-port=}"; shift ;;
		--ports)
			[ $# -ge 2 ] || die "--ports requires a comma-separated list"
			PORTS="$2"; shift 2 ;;
		--ports=*)
			PORTS="${1#--ports=}"; shift ;;
		--isolate)
			[ $# -ge 2 ] || die "--isolate requires a list (docker, db, db=schema, db=database)"
			ISOLATE="${ISOLATE:+$ISOLATE,}$2"; shift 2 ;;
		--isolate=*)
			ISOLATE="${ISOLATE:+$ISOLATE,}${1#--isolate=}"; shift ;;
		--canonical-port)
			[ $# -ge 2 ] || die "--canonical-port requires a value"
			CANONICAL_PORT="$2"; shift 2 ;;
		--canonical-port=*)
			CANONICAL_PORT="${1#--canonical-port=}"; shift ;;
		--canonical-takeover)
			CANONICAL_TAKEOVER=1; shift ;;
		--no-probe)
			NO_PROBE=1; shift ;;
		--no-gate)
			NO_GATE=1; shift ;;
		--force-isolation)
			FORCE_ISOLATION=1; shift ;;
		--no-guide)
			NO_GUIDE=1; shift ;;
		--dry-run)
			DRYRUN=1; shift ;;
		-h|--help)
			usage; exit 0 ;;
		--)
			shift; break ;;
		-*)
			die "unknown option: $1 (try --help)" ;;
		*)
			break ;;
	esac
done

# --- validate -----------------------------------------------------------------
[ $# -ge 1 ] || { usage >&2; die "no command given — a command to run is required"; }

if [ "$USE_HOME" = "1" ] && [ -n "$DIR" ]; then
	die "--home and --dir are mutually exclusive"
fi

case "$STATUS" in
	busy|blocked|done|idle) ;;
	*) die "unknown status: $STATUS (one of: busy, blocked, done, idle)" ;;
esac

# --- resolve the working directory -------------------------------------------
# Precedence: --home > --dir > inherit \$PWD (the default).
if [ "$USE_HOME" = "1" ]; then
	CWD="$HOME"
elif [ -n "$DIR" ]; then
	CWD="$DIR"
else
	CWD="$PWD"
fi

# Locate emit (absolute path for use in the new session).
if ! EMIT="$(find_emit)"; then
	die "cannot find it2agent-emit (looked next to this script and on PATH)"
fi

# The command to run in the new tab is the remaining args.
# Preserve them as a list for both dry-run display and shell quoting.

# --- shell-quote a single argument (single-quote wrapping, POSIX-safe) --------
shq() {
	# Wrap in single quotes, escaping any embedded single quote as '\''.
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

# --- AppleScript string escape (backslash, then double-quote) -----------------
as_esc() {
	printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

# --- capture the user command (trailing args) NOW ----------------------------
# We snapshot $@ into RUN_CMD before the isolation block, because that block
# uses `set --` to assemble helper args and would otherwise clobber $@.
RUN_CMD=""
for a in "$@"; do
	if [ -z "$RUN_CMD" ]; then
		RUN_CMD="$(shq "$a")"
	else
		RUN_CMD="$RUN_CMD $(shq "$a")"
	fi
done

# --- worktree + port/namespace isolation (issue #13) -------------------------
# Gated on agent.worktree_isolation. When OFF (the default) this whole block
# is a no-op and spawn behaves EXACTLY as #10: plain $PWD inheritance, no
# worktree, no port. When ON, we delegate to the sibling it2agent-worktree
# helper to create a per-agent worktree on its own branch, override the cwd to
# that worktree, and export the per-agent $IT2AGENT_PORT / $IT2AGENT_NS (plus
# _WORKTREE / _BRANCH) into the new session before the command runs.
ISOLATION_EXPORTS=""   # export lines injected into the session (empty when OFF)
ISOLATION_PLAN=""      # human-readable plan captured from the helper (dry-run)
ISOLATION_ON=0
ISO_FORCED=0           # 1 when isolation is ON via --force-isolation (flag bypassed)

# Gate (bug P2 fix): worktree isolation is opt-in via its OWN flag. Unlike the
# emit gate, it is NOT bypassed by --no-gate / IT2AGENT_FORCE — those only affect
# the identity emits. Isolation turns ON only when agent.worktree_isolation is
# true, or when explicitly forced with --force-isolation / IT2AGENT_FORCE_ISOLATION.
iso_gate_open() {
	if [ "$FORCE_ISOLATION" = "1" ]; then
		ISO_FORCED=1
		return 0
	fi
	fl="$(find_flag 2>/dev/null)" || return 1
	if "$fl" agent.worktree_isolation >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

if iso_gate_open; then
	ISOLATION_ON=1
	if ! WT="$(find_worktree)"; then
		die "worktree isolation is ON but it2agent-worktree was not found (next to this script or on PATH)"
	fi
	# Isolation requires a git repo; resolve the top-level from the resolved cwd.
	REPO_ROOT="$(git -C "$CWD" rev-parse --show-toplevel 2>/dev/null)" \
		|| die "worktree isolation is ON but $CWD is not inside a git repository"

	# Derive the agent id if not given explicitly.
	iso_id="$AGENT_ID"
	if [ -z "$iso_id" ]; then
		if [ -n "$ROLE" ] && [ -n "$TASK" ]; then iso_id="$ROLE-$TASK"
		elif [ -n "$ROLE" ]; then iso_id="$ROLE"
		elif [ -n "$TASK" ]; then iso_id="$TASK"
		else die "worktree isolation is ON but no --id (or --role/--task) to derive an agent id from"
		fi
	fi

	# Assemble the helper args. The worktree helper also self-gates on
	# agent.worktree_isolation, so when isolation is ON via the flag it opens on
	# its own. Only when we FORCED isolation past an OFF flag (--force-isolation)
	# do we forward --no-gate, so the helper runs in lockstep with this wrapper.
	set -- create --repo "$REPO_ROOT" --id "$iso_id"
	[ -n "$ROLE" ] && set -- "$@" --role "$ROLE"
	[ -n "$TASK" ] && set -- "$@" --task "$TASK"
	[ -n "$BASE_PORT" ] && set -- "$@" --base-port "$BASE_PORT"
	[ -n "$PORTS" ] && set -- "$@" --ports "$PORTS"
	[ -n "$ISOLATE" ] && set -- "$@" --isolate "$ISOLATE"
	[ -n "$CANONICAL_PORT" ] && set -- "$@" --canonical-port "$CANONICAL_PORT"
	[ "$CANONICAL_TAKEOVER" = "1" ] && set -- "$@" --canonical-takeover
	[ "$NO_PROBE" = "1" ] && set -- "$@" --no-probe
	[ "$ISO_FORCED" = "1" ] && set -- "$@" --no-gate
	[ "$DRYRUN" = "1" ] && set -- "$@" --dry-run

	if ! ISOLATION_PLAN="$("$WT" "$@")"; then
		die "it2agent-worktree create failed (see errors above)"
	fi

	# Parse the allocation the helper printed on stdout (key=value lines).
	iso_val() { printf '%s\n' "$ISOLATION_PLAN" | sed -n "s/^$1=//p" | head -1; }
	ISO_WORKTREE="$(iso_val worktree)"
	ISO_PORT="$(iso_val port)"
	ISO_NS="$(iso_val namespace)"
	ISO_BRANCH="$(iso_val branch)"
	[ -n "$ISO_WORKTREE" ] || die "it2agent-worktree did not return a worktree path"

	# The worktree becomes the working directory (replacing plain cwd inheritance).
	CWD="$ISO_WORKTREE"

	# Any NAMED port (--ports), CANONICAL port, and service-isolation (--isolate)
	# export the helper emitted become additional exports. We blindly turn each
	# `port_<name>=` / `canonical_port_<name>=` plan line into
	# IT2AGENT_PORT_<UPPER> / IT2AGENT_CANONICAL_PORT_<UPPER>, and each already-named
	# `env_<NAME>=` line (e.g. env_COMPOSE_PROJECT_NAME, env_IT2AGENT_DB_SCHEMA,
	# env_PGOPTIONS) into a plain `export <NAME>=`. When neither --ports nor
	# --isolate was given (with its flag ON) there are none, so this is empty (= #13).
	iso_extra_exports() {
		printf '%s\n' "$ISOLATION_PLAN" | while IFS= read -r line; do
			case "$line" in
				port_*=*)
					nm="${line%%=*}"; nm="${nm#port_}"; v="${line#*=}"
					printf 'export IT2AGENT_PORT_%s=%s\n' "$(printf '%s' "$nm" | tr '[:lower:]' '[:upper:]')" "$(shq "$v")" ;;
				canonical_port_*=*)
					nm="${line%%=*}"; nm="${nm#canonical_port_}"; v="${line#*=}"
					printf 'export IT2AGENT_CANONICAL_PORT_%s=%s\n' "$(printf '%s' "$nm" | tr '[:lower:]' '[:upper:]')" "$(shq "$v")" ;;
				env_*=*)
					nm="${line%%=*}"; nm="${nm#env_}"; v="${line#*=}"
					printf 'export %s=%s\n' "$nm" "$(shq "$v")" ;;
			esac
		done
	}
	ISO_EXTRA="$(iso_extra_exports)"

	# Exports written into the new session BEFORE the command runs.
	ISOLATION_EXPORTS="export IT2AGENT_PORT=$(shq "$ISO_PORT")
${ISO_EXTRA:+$ISO_EXTRA
}export IT2AGENT_NS=$(shq "$ISO_NS")
export IT2AGENT_WORKTREE=$(shq "$ISO_WORKTREE")
export IT2AGENT_BRANCH=$(shq "$ISO_BRANCH")
"
fi

# --- build the shell commands to write into the new session ------------------
# 1) cd into the resolved cwd (the worktree when isolation is ON, else $PWD).
CD_CMD="cd $(shq "$CWD")"

# 2) identity emits. --no-gate is forwarded when requested so the operator's
#    force/bypass intent survives into the new session.
GATE_ARG=""
[ "$NO_GATE" = "1" ] && GATE_ARG=" --no-gate"

EMIT_CMDS=""
add_emit() {
	# $*: the emit subcommand + args, already individually shell-quoted.
	EMIT_CMDS="${EMIT_CMDS}$(shq "$EMIT")${GATE_ARG} $*
"
}
[ -n "$ROLE" ] && add_emit "role $(shq "$ROLE")"
[ -n "$TASK" ] && add_emit "task $(shq "$TASK")"
add_emit "status $(shq "$STATUS")"
add_emit "color $(shq "$STATUS")"
add_emit "badge"

# NATIVE tab status (OSC 21337) — cooperate with iTerm2's native tab-status /
# Cockpit channel (#89, follow-up to #87/#88). We ALWAYS append this line; it is
# NOT gated here. it2agent-emit ccstatus SELF-GATES on agent.native_status, so
# when that flag is OFF (the default) the call emits nothing and exits 0 — a
# no-op that leaves the current behavior unchanged. The detail mirrors the
# badge's own role/task composition (role · task, else whichever is set); when
# both are empty we omit --detail. --no-gate rides through via GATE_ARG exactly
# like the identity emits above.
CCSTATUS_DETAIL=""
if [ -n "$ROLE" ] && [ -n "$TASK" ]; then
	CCSTATUS_DETAIL="$ROLE · $TASK"
elif [ -n "$ROLE" ]; then
	CCSTATUS_DETAIL="$ROLE"
elif [ -n "$TASK" ]; then
	CCSTATUS_DETAIL="$TASK"
fi
if [ -n "$CCSTATUS_DETAIL" ]; then
	add_emit "ccstatus $(shq "$STATUS") --detail $(shq "$CCSTATUS_DETAIL")"
else
	add_emit "ccstatus $(shq "$STATUS")"
fi

# 3) capability-guide header (#56). A SHORT (1-line) pointer to the consolidated
#    guide is printed into the new session AFTER the identity emits, so a fresh
#    agent learns the capabilities exist. It does NOT dump the guide — it points
#    at `it2agent help`. Suppressed with --no-guide. Not gated (a hint, not a
#    capability). We echo it via printf so it appears in the session's scrollback.
GUIDE_CMD=""
if [ "$NO_GUIDE" != "1" ]; then
	GUIDE_LINE="# it2agent capabilities available — run: it2agent help"
	GUIDE_CMD="printf '%s\n' $(shq "$GUIDE_LINE")
"
fi

# 4) the user command was captured into RUN_CMD above (before the isolation
#    block, which uses `set --`).

# The full script written into the new session, one command per line. When
# isolation is ON the per-agent env exports go right after the cd, so they are
# in scope for both the identity emits and the agent command.
SESSION_SCRIPT="$CD_CMD
${ISOLATION_EXPORTS}${EMIT_CMDS}${GUIDE_CMD}${RUN_CMD}"

# --- deliver via a tmpfile, NOT by typing the whole script (bug P1 fix) -------
# Typing a long multi-line script into the new tab's interactive shell via
# AppleScript `write text` corrupts it two ways: long single lines get mangled by
# zle/syntax-highlight/autosuggest, and long/UTF-8 payloads mangle the
# shell->AppleScript->iTerm transport. So we write the script to a short-path
# tmpfile and type ONE short line that sources it with `.` and self-removes.
# (Technique proven in the operator's ~/bin iTerm helpers; reimplemented here to
# stay self-contained.) The new tab is a separate login shell, so the file must
# live on a shared filesystem — /tmp (kept short to keep the typed line short).
if [ "$DRYRUN" = "1" ]; then
	BOOT="/tmp/it2agent-boot.XXXXXX"   # placeholder path; no file created in dry-run
else
	BOOT="$(mktemp /tmp/it2agent-boot.XXXXXX)" || die "could not create boot tmpfile under /tmp"
	chmod 600 "$BOOT"
	printf '%s\n' "$SESSION_SCRIPT" > "$BOOT"
fi
# --- delivery: launch the boot as the session's COMMAND (bug #74 fix) --------
# The P1 fix above stopped TYPING the long script (it now lives in the boot
# file). But the boot file was still reached by TYPING a short `. <file>` line
# into the new tab's interactive shell via AppleScript `write text`. That typing
# is racy two ways (proven live in AC1, #74): (A) `write text` targeted
# `current session of targetWindow`, re-read after `create tab`, so back-to-back
# spawns could write into the wrong/not-yet-current session; (B) it fed the new
# shell's line editor (zle) before it was ready, so stray typeahead/autosuggest
# bytes got prepended (observed `que.`/`foi ` → `command not found`), the source
# failed, and identity was never stamped.
#
# Fix: do NOT type anything. Launch the boot directly as the session's PROGRAM
# via iTerm2's `command` parameter on `create tab`/`create window`. The command
# runs in exactly the tab we create (so (A) is gone by construction — there is
# no `current session` lookup and no `write text`), and nothing ever touches a
# line editor (so (B) is gone). The program is a login shell that sources the
# boot file, self-removes it, then re-execs an interactive login shell so the
# tab stays usable after the agent command returns (matching the old UX).
LAUNCH_SHELL="${SHELL:-/bin/sh}"
case "$LAUNCH_SHELL" in
	*[!A-Za-z0-9/._-]*) LAUNCH_SHELL="/bin/sh" ;;  # refuse odd $SHELL paths
esac
# The boot path is a mktemp slug (/tmp/it2agent-boot.XXXXXX): no spaces/quotes,
# safe to embed unquoted. Keep the inner free of single quotes so the outer
# single-quote wrap (shq) stays clean.
BOOT_INNER=". $BOOT; rm -f $BOOT; exec $LAUNCH_SHELL -l"
LAUNCH_CMD="$LAUNCH_SHELL -lc $(shq "$BOOT_INNER")"

# --- assemble the AppleScript -------------------------------------------------
# Create a tab in the current window (or a new window if none is open) whose
# `command` IS the launch line. No `write text`, no `current session`.
AS_BODY="$(as_esc "$LAUNCH_CMD")"
build_applescript() {
	cat <<APPLESCRIPT
tell application "iTerm2"
	if (count of windows) = 0 then
		create window with default profile command "${AS_BODY}"
	else
		tell current window to create tab with default profile command "${AS_BODY}"
	end if
end tell
APPLESCRIPT
}

APPLESCRIPT_TEXT="$(build_applescript)"

# --- dry-run: print the plan, execute nothing --------------------------------
if [ "$DRYRUN" = "1" ]; then
	printf '%s: DRY RUN (nothing executed)\n' "$PROG"
	printf '  resolved cwd : %s\n' "$CWD"
	printf '  emit helper  : %s\n' "$EMIT"
	printf '  gate bypass  : %s\n' "$([ "$NO_GATE" = 1 ] && echo 'yes (--no-gate forwarded)' || echo 'no (emit self-gates on agent.status_board)')"
	if [ "$ISOLATION_ON" = "1" ]; then
		iso_why="$([ "$ISO_FORCED" = 1 ] && echo '--force-isolation' || echo 'agent.worktree_isolation')"
		printf '  isolation    : ON (%s) — per-agent worktree + port\n' "$iso_why"
	else
		printf '  isolation    : off (plain $PWD inheritance, = #10)\n'
	fi
	printf '  guide header : %s\n' "$([ "$NO_GUIDE" = 1 ] && echo 'off (--no-guide)' || echo 'on (run: it2agent help)')"
	printf '  delivery     : the script below is written to a /tmp boot file; the tab is created with `command` = `%s -lc ". <file>; rm -f <file>; exec %s -l"` (launched directly, NOT typed into a shell — no zle race, #74)\n' "$LAUNCH_SHELL" "$LAUNCH_SHELL"
	if [ "$ISOLATION_ON" = "1" ]; then
		printf '\n  worktree isolation plan (from it2agent-worktree):\n'
		printf '%s\n' "$ISOLATION_PLAN" | sed 's/^/    /'
	fi
	printf '\n  commands written into the new session (the boot file):\n'
	printf '%s\n' "$SESSION_SCRIPT" | sed 's/^/    /'
	printf '\n  AppleScript that WOULD run:\n'
	printf '%s\n' "$APPLESCRIPT_TEXT" | sed 's/^/    /'
	exit 0
fi

# --- execute ------------------------------------------------------------------
command -v osascript >/dev/null 2>&1 || die "osascript not found (this wrapper requires macOS/iTerm2)"
# Discard osascript's stdout (it echoes the created-tab reference); keep stderr
# so real AppleScript/iTerm errors still surface.
printf '%s\n' "$APPLESCRIPT_TEXT" | osascript - >/dev/null
