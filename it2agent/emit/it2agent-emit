#!/usr/bin/env sh
# it2agent-emit — emit iTerm2 proprietary escape codes so an agent can signal
# its own state (status/role/task/attention/mark/progress).
#
# it2agent Tier 0.1 (#7). scope:external-tooling — runs *on* iTerm2's escape
# codes; never modifies iTerm2 source.
#
# Framing (per iTerm2 "Proprietary Escape Codes" docs):
#   OSC = ESC ]                    (0x1b 0x5d)
#   ST  = BEL                      (0x07)  <- iTerm2-documented terminator
# Sequences emitted:
#   status|role|task <v> -> ESC ] 1337 ; SetUserVar=agent_<k>=<base64(v)> BEL
#   attention [msg]      -> ESC ] 1337 ; RequestAttention=yes BEL
#                           ESC ] 9 ; <msg> BEL
#   mark                 -> ESC ] 1337 ; SetMark BEL
#   progress <st> <pct>  -> ESC ] 9 ; 4 ; <st> ; <pct> BEL   (ConEmu style)
#   color <role|status>  -> ESC ] 1337 ; SetColors=tab=<RRGGBB> BEL
#   badge [format]       -> ESC ] 1337 ; SetBadgeFormat=<base64(format)> BEL
#   ccstatus <status>    -> ESC ] 21337 ; status=<TEXT> ; indicator=#<hex> BEL
#
# The tab-color key is `tab` (verified against iTerm2's it2setcolor utility and
# the SetColors parser); iTerm2 has no `tabbg` key. The lifecycle palette is
# colorblind-safe (Okabe-Ito); see it2agent/emit/docs/colors.md.
#
# `ccstatus` cooperates with iTerm2's NATIVE tab-status channel (OSC 21337 —
# the one that feeds the native tab status and the Cockpit / cc-status hook),
# rather than the parallel SetUserVar board. OSC 21337 values are LITERAL (not
# base64) semicolon-delimited key=value pairs; `;` and `\` are escaped as `\;`
# and `\\`, and an empty value clears a key. See VT100Terminal.m
# executeSetTabStatus + sources/Toolbelt/ToolStatus.swift.
#
# Gating: every capability gates on its feature flag. Most gate on
# `agent.status_board`; `ccstatus` gates on the separate `agent.native_status`
# so the native channel is opt-in independently of the parallel board. Both are
# checked via the external `it2agent-flag` helper (#11).
# If the flag is OFF/absent, or it2agent-flag is not on PATH, emit nothing and
# exit 0 quietly (fail-safe: capabilities are off by default). Bypass for local
# testing with `--no-gate` or the env override IT2AGENT_FORCE=1.
#
# Secrets: the ONLY thing written to stdout is the escape sequence itself.
# Values that iTerm2 requires base64 for (SetUserVar) are base64'd; nothing is
# ever logged to stderr on the success path.
set -eu

PROG="it2agent-emit"
FLAG_KEY="agent.status_board"
# ccstatus emits on the native OSC 21337 channel; it gates on its own flag.
FLAG_KEY_NATIVE="agent.native_status"
DEFAULT_ATTENTION_MSG="it2agent: agent needs attention"
# Default badge interpolates the user vars set by `role`/`task`. iTerm2 forbids
# `.` in a SetUserVar key (PTYSession.screenSetUserVar: rejects it) and prefixes
# `user.` itself, so `SetUserVar=agent_<k>` becomes `user.agent_<k>`. Middle dot
# separates role and task in the displayed badge.
DEFAULT_BADGE_FORMAT='\(user.agent_role) · \(user.agent_task)'

usage() {
	cat <<EOF
$PROG — emit iTerm2 escape codes to signal agent state.

Usage:
  $PROG [--no-gate] <command> [args]

Commands:
  status <value>          Set user var agent_status (base64'd).
  role <value>            Set user var agent_role (base64'd).
  task <value>            Set user var agent_task (base64'd).
  attention [message]     RequestAttention=yes + an OSC 9 notification.
                          Default message: "$DEFAULT_ATTENTION_MSG"
  mark                    Emit SetMark.
  progress <state> <pct>  ConEmu progress. state in {0,1,2,3,4}, pct in 0..100.
                          0=remove 1=normal 2=error 3=indeterminate 4=paused
  color <role-or-status>  Set the tab color (SetColors=tab). Accepts a lifecycle
                          status (busy, blocked, done, idle) mapped to a
                          colorblind-safe hex, or a raw RGB/RRGGBB hex.
  badge [format]          Set the session badge (SetBadgeFormat, base64'd).
                          Default: $DEFAULT_BADGE_FORMAT
  ccstatus <status>       Set the NATIVE tab status (OSC 21337) shown in
    [--detail <text>]     iTerm2's tab status + Cockpit. <status> is a lifecycle
                          keyword (busy, blocked, done, idle) — capitalized and
                          given the matching lifecycle indicator color — or free
                          text. --detail adds the optional detail line.
  ccstatus clear          Clear the native tab status.

Options:
  --no-gate               Bypass the feature-flag gate (local testing).
  -h, --help              Show this help.

Environment:
  IT2AGENT_FORCE=1       Bypass the feature-flag gate (local testing).

Gating: emits only when the governing feature flag is ON (checked via the
it2agent-flag helper). Most commands gate on "$FLAG_KEY"; ccstatus gates on
"$FLAG_KEY_NATIVE". Otherwise emits nothing and exits 0.
EOF
}

die() {
	# Usage/validation errors go to stderr. Never echoes emitted values.
	printf '%s: %s\n' "$PROG" "$1" >&2
	exit 2
}

# Returns 0 if the capability is enabled (or gating is bypassed), else 1.
# $1 = the feature-flag key this command gates on.
gate_open() {
	if [ "${IT2AGENT_FORCE:-}" = "1" ]; then
		return 0
	fi
	if [ "$NO_GATE" = "1" ]; then
		return 0
	fi
	# Fail-safe: if the flag helper isn't on PATH, treat the flag as OFF.
	if ! command -v it2agent-flag >/dev/null 2>&1; then
		return 1
	fi
	# it2agent-flag prints 1/exit0 when ON, 0/exit1 when OFF. Swallow its
	# stdout so nothing but our escape sequence ever reaches our stdout.
	if it2agent-flag "$1" >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

b64() {
	# Standard base64, single line (Linux `base64` wraps at 76 cols).
	printf '%s' "$1" | base64 | tr -d '\n'
}

# Escape text for a native OSC 21337 value: `\` -> `\\`, then `;` -> `\;`
# (order matters). Matches VT100Terminal.m executeSetTabStatus' parser.
esc21337() {
	printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/;/\\;/g'
}

# Wrap a body in OSC ... BEL and write raw bytes to stdout. The body is passed
# as a %s argument, so any '%' inside a user message is not re-interpreted.
osc() {
	printf '\033]%s\007' "$1"
}

is_uint() {
	case "$1" in
		'' | *[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

is_hex() {
	# True for a 3- or 6-digit hex color (case-insensitive), no leading '#'.
	case "$1" in
		[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) return 0 ;;
		[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) return 0 ;;
		*) return 1 ;;
	esac
}

# Map a lifecycle status (or role) to a colorblind-safe hex (Okabe-Ito), or
# pass a raw hex through. Echoes RRGGBB on success; returns 1 for unknown input.
# Palette rationale + exact bytes: it2agent/emit/docs/colors.md.
color_for() {
	case "$1" in
		busy)    printf '0072B2' ;;
		blocked) printf 'E69F00' ;;
		done)    printf '009E73' ;;
		idle)    printf '999999' ;;
		*)
			if is_hex "$1"; then printf '%s' "$1"; else return 1; fi
			;;
	esac
}

# --- parse leading global options -------------------------------------------
NO_GATE=0
while [ $# -gt 0 ]; do
	case "$1" in
		--no-gate)
			NO_GATE=1
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		--)
			shift
			break
			;;
		-*)
			die "unknown option: $1"
			;;
		*)
			break
			;;
	esac
done

[ $# -ge 1 ] || {
	usage >&2
	exit 2
}

cmd="$1"
shift

# --- validate args & build the sequence BEFORE consulting the gate -----------
# (Bad input is a usage error even when gated off, so validate first.)
seq=""
# The flag this command gates on. Most use the status board; ccstatus opts into
# the native OSC 21337 channel via its own flag.
flag="$FLAG_KEY"
case "$cmd" in
	status | role | task)
		[ $# -eq 1 ] || die "$cmd requires exactly one <value> argument"
		seq="$(osc "1337;SetUserVar=agent_$cmd=$(b64 "$1")")"
		;;
	attention)
		if [ $# -ge 1 ]; then
			msg="$*"
		else
			msg="$DEFAULT_ATTENTION_MSG"
		fi
		seq="$(osc '1337;RequestAttention=yes')$(osc "9;$msg")"
		;;
	mark)
		[ $# -eq 0 ] || die "mark takes no arguments"
		seq="$(osc '1337;SetMark')"
		;;
	progress)
		[ $# -eq 2 ] || die "progress requires <state> and <pct>"
		state="$1"
		pct="$2"
		case "$state" in
			0 | 1 | 2 | 3 | 4) ;;
			*) die "progress state must be one of 0,1,2,3,4 (got: $state)" ;;
		esac
		is_uint "$pct" || die "progress pct must be an integer 0..100 (got: $pct)"
		[ "$pct" -ge 0 ] && [ "$pct" -le 100 ] || die "progress pct must be 0..100 (got: $pct)"
		seq="$(osc "9;4;$state;$pct")"
		;;
	color)
		[ $# -eq 1 ] || die "color requires exactly one <role-or-status> argument"
		hex="$(color_for "$1")" || die "unknown status/role: $1 (known: busy, blocked, done, idle; or pass a RGB/RRGGBB hex)"
		seq="$(osc "1337;SetColors=tab=$hex")"
		;;
	badge)
		if [ $# -ge 1 ]; then
			fmt="$*"
		else
			fmt="$DEFAULT_BADGE_FORMAT"
		fi
		seq="$(osc "1337;SetBadgeFormat=$(b64 "$fmt")")"
		;;
	ccstatus)
		flag="$FLAG_KEY_NATIVE"
		# Parse: <status> plus optional --detail <text>, or the literal `clear`.
		status_arg=""
		have_status=0
		detail=""
		have_detail=0
		while [ $# -gt 0 ]; do
			case "$1" in
				--detail)
					[ $# -ge 2 ] || die "ccstatus --detail requires a <text> value"
					detail="$2"
					have_detail=1
					shift 2
					;;
				*)
					[ "$have_status" -eq 0 ] || die "ccstatus takes exactly one <status> (or 'clear')"
					status_arg="$1"
					have_status=1
					shift
					;;
			esac
		done
		[ "$have_status" -eq 1 ] || die "ccstatus requires a <status> (busy|blocked|done|idle|text) or 'clear'"
		if [ "$status_arg" = "clear" ]; then
			[ "$have_detail" -eq 0 ] || die "ccstatus clear takes no --detail"
			# Empty values clear each native key.
			seq="$(osc '21337;status=;indicator=;detail=')"
		else
			# Lifecycle keywords get a capitalized label + the matching
			# lifecycle indicator hex (reusing the palette in color_for);
			# anything else is free text with no indicator.
			ind=""
			case "$status_arg" in
				busy)    label="Busy" ;;
				blocked) label="Blocked" ;;
				done)    label="Done" ;;
				idle)    label="Idle" ;;
				*)       label="" ;;
			esac
			if [ -n "$label" ]; then
				ind="#$(color_for "$status_arg")"
			else
				label="$(esc21337 "$status_arg")"
			fi
			body="21337;status=$label"
			[ -n "$ind" ] && body="$body;indicator=$ind"
			[ "$have_detail" -eq 1 ] && body="$body;detail=$(esc21337 "$detail")"
			seq="$(osc "$body")"
		fi
		;;
	*)
		die "unknown command: $cmd (try --help)"
		;;
esac

# --- gate, then emit ----------------------------------------------------------
if ! gate_open "$flag"; then
	exit 0
fi

printf '%s' "$seq"
