#!/usr/bin/env sh
# it2agent-uninstall — remove the PATH wrappers that `it2agent install` created
# (#120), and only those. A wrapper is ours iff it is a tiny `exec "<path>" "$@"`
# stub whose target points back into this repo's tooling dir. Unrelated files in
# the bindir are never touched. Root sibling of the umbrella so
# `it2agent uninstall` resolves from a fresh checkout.
#
# scope:external-tooling — pure shell glue; removes only wrappers it recognizes
# as its own and never modifies iTerm2 source.
set -u

PROG="it2agent-uninstall"

usage() {
	cat <<EOF
$PROG — remove the it2agent PATH wrappers installed by it2agent install.

Usage:
  $PROG [--dir <bindir>]   Remove wrappers in <bindir> (default ~/.local/bin)
                           whose target points into this repo. Only wrappers we
                           created are removed; unrelated files are left alone.
  $PROG -h | --help        Show this help.
EOF
}

# --- resolve this script's directory (the repo tooling dir, absolute) --------
script_dir() {
	d="$(dirname "$0")"
	(cd "$d" 2>/dev/null && pwd)
}
ROOT="$(script_dir)"
if [ -z "$ROOT" ]; then
	printf '%s: cannot resolve script directory\n' "$PROG" >&2
	exit 1
fi

BINDIR="$HOME/.local/bin"

# --- parse args --------------------------------------------------------------
while [ "$#" -gt 0 ]; do
	case "$1" in
		-h|--help) usage; exit 0 ;;
		--dir)
			if [ "$#" -lt 2 ]; then
				printf '%s: --dir requires an argument\n' "$PROG" >&2
				exit 2
			fi
			BINDIR="$2"; shift 2 ;;
		--dir=*) BINDIR="${1#--dir=}"; shift ;;
		*)
			printf '%s: unexpected argument: %s\n' "$PROG" "$1" >&2
			usage >&2
			exit 2 ;;
	esac
done

if [ ! -d "$BINDIR" ]; then
	printf '%s: bindir does not exist: %s (nothing to remove)\n' "$PROG" "$BINDIR"
	exit 0
fi

# --- remove only our wrappers ------------------------------------------------
# A wrapper we wrote is a regular file (not a symlink) containing a line
# `exec "<abs-path>" "$@"` whose <abs-path> lives under this repo's tooling dir.
count=0
printf 'Removing it2agent wrappers from %s:\n' "$BINDIR"
for f in "$BINDIR"/*; do
	[ -e "$f" ] || continue          # empty-glob guard
	[ -f "$f" ] || continue          # only regular files
	[ -L "$f" ] && continue          # never follow/remove symlinks
	# Extract the exec target (the path inside the first `exec "..." "$@"` line).
	target="$(sed -n 's/^exec "\(.*\)" "$@"$/\1/p' "$f" 2>/dev/null | head -n 1)"
	[ -n "$target" ] || continue
	case "$target" in
		"$ROOT"/*)
			rm -f "$f"
			count=$((count + 1))
			printf '  %s\n' "$(basename "$f")" ;;
		*) : ;;                      # not ours — leave it alone
	esac
done

printf 'Removed %s wrapper(s).\n' "$count"
