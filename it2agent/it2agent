#!/usr/bin/env sh
# it2agent — thin umbrella dispatcher (#56).
#
# A convenience front door so `it2agent help` works from a spawned agent's tab.
# It does NOT re-implement anything: `help` (and the no-arg case) delegate to the
# sibling `it2agent-help`; any other subcommand <cmd> is forwarded to the
# sibling `it2agent-<cmd>` (e.g. `it2agent flag list` -> `it2agent-flag list`).
#
# scope:external-tooling — pure shell glue; never modifies iTerm2 source.
set -u

PROG="it2agent"

script_dir() {
	d="$(dirname "$0")"
	(cd "$d" 2>/dev/null && pwd)
}

SD="$(script_dir)"

usage() {
	cat <<EOF
$PROG — it2agent umbrella dispatcher.

Usage:
  $PROG help              Print the capability guide (delegates to it2agent-help).
  $PROG brief             Print a short, live summary of active capabilities.
  $PROG guide [--check]   Regenerate AGENT_GUIDE.md from the flag schema + MCP
                          tools (--check fails on drift).
  $PROG install [--dir D] Install PATH wrappers for every it2agent CLI into D
                          (default ~/.local/bin) so the GUI and you can find
                          them from anywhere.
  $PROG uninstall [--dir D] Remove the wrappers install created (only ours).
  $PROG <cmd> [args...]   Run the sibling tool it2agent-<cmd> (e.g. flag, emit,
                          spawn, broker, review, janitor, cost, inbox, mcp, tmux).
  $PROG -h | --help       Show this help.
EOF
}

# Resolve a sibling tool: prefer the copy next to this script, else PATH.
resolve_tool() {
	# $1 = tool basename, e.g. it2agent-help
	if [ -n "$SD" ] && [ -x "$SD/$1" ]; then
		printf '%s/%s' "$SD" "$1"
		return 0
	fi
	if command -v "$1" >/dev/null 2>&1; then
		command -v "$1"
		return 0
	fi
	return 1
}

if [ "$#" -eq 0 ]; then
	# No subcommand: show the guide (most useful default for a fresh agent).
	set -- help
fi

sub="$1"; shift

case "$sub" in
	-h|--help)
		usage
		exit 0
		;;
	help)
		if tool="$(resolve_tool it2agent-help)"; then
			exec "$tool" "$@"
		fi
		printf '%s: it2agent-help not found\n' "$PROG" >&2
		exit 1
		;;
	*)
		if tool="$(resolve_tool "it2agent-$sub")"; then
			exec "$tool" "$@"
		fi
		printf '%s: unknown subcommand: %s (no it2agent-%s found)\n' "$PROG" "$sub" "$sub" >&2
		usage >&2
		exit 2
		;;
esac
