#!/usr/bin/env bash
# spawnterm i18n lookup helper (canonical shell implementation).
#
# Cross-cutting i18n foundation for spawnTerm surfaces (#66). English is the
# default; pt-BR ships alongside and the framework is extensible (drop a new
# <lang>.json catalog in this directory). This is the canonical CLI;
# spawnterm_i18n.py is the parity twin for Python environments.
#
#   spawnterm-i18n t <key> [args...]   localized string, fallback active->en->key
#   spawnterm-i18n lang                resolved active language (en or pt-BR)
#
# Active language is read from [settings] language in the shared config
# ($XDG_CONFIG_HOME/spawnterm/config.toml, same resolution as spawnterm-flag).
# Valid: en, pt-BR, system. Missing/invalid reads as en and never writes.
# system resolves from $LC_ALL/$LANG (a "pt" prefix -> pt-BR, else en).
# Interpolation is positional with {0} {1} placeholders.
#
# Docs: spawnterm/i18n/README.md
set -u

PROG="spawnterm-i18n"
DEFAULT_LANGUAGE="en"

SD="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"

err() {
  printf '%s: %s\n' "$PROG" "$1" >&2
}

config_path() {
  # Precedence: $SPAWNTERM_CONFIG > $XDG_CONFIG_HOME > ~/.config
  if [ -n "${SPAWNTERM_CONFIG:-}" ]; then
    printf '%s' "$SPAWNTERM_CONFIG"
    return
  fi
  local base="${XDG_CONFIG_HOME:-}"
  if [ -z "$base" ]; then
    base="$HOME/.config"
  fi
  printf '%s/spawnterm/config.toml' "$base"
}

configured_language() {
  # Echo the raw [settings] language value, or the default when absent/invalid.
  local file line val
  file="$(config_path)"
  if [ -f "$file" ]; then
    line="$(grep -E '^[[:space:]]*language[[:space:]]*=' "$file" 2>/dev/null | head -1)"
    if [ -n "$line" ]; then
      val="$(printf '%s' "$line" | sed -E 's/^[^=]*=[[:space:]]*"?([A-Za-z-]+)"?.*/\1/')"
      case "$val" in
        en|pt-BR|system) printf '%s' "$val"; return ;;
      esac
    fi
  fi
  printf '%s' "$DEFAULT_LANGUAGE"
}

resolve_system() {
  # Resolve the "system" pseudo-language from the locale environment.
  local locale="${LC_ALL:-}"
  [ -n "$locale" ] || locale="${LANG:-}"
  case "$(printf '%s' "$locale" | tr '[:upper:]' '[:lower:]')" in
    pt*) printf 'pt-BR' ;;
    *)   printf 'en' ;;
  esac
}

active_language() {
  local lang; lang="$(configured_language)"
  if [ "$lang" = "system" ]; then
    resolve_system
  else
    printf '%s' "$lang"
  fi
}

catalog_lookup() {
  # $1 = lang, $2 = key. Echo the value and return 0 if found, else return 1.
  # Catalog is JSON with one "key": "value" entry per line; values contain no
  # embedded double-quotes or backslashes (see spawnterm/i18n/README.md).
  local lang="$1" key="$2" file ekey line
  file="$SD/${lang}.json"
  [ -f "$file" ] || return 1
  ekey="$(printf '%s' "$key" | sed 's/[.[\*^$]/\\&/g')"
  line="$(grep -E "^[[:space:]]*\"${ekey}\"[[:space:]]*:" "$file" 2>/dev/null | head -1)"
  [ -n "$line" ] || return 1
  printf '%s' "$line" | sed -E 's/^[[:space:]]*"[^"]*"[[:space:]]*:[[:space:]]*"(.*)"[[:space:]]*,?[[:space:]]*$/\1/'
}

interpolate() {
  # $1 = template; remaining args = positional values for {0} {1} ...
  local template="$1"; shift
  local i=0 arg
  for arg in "$@"; do
    template="${template//\{$i\}/$arg}"
    i=$((i + 1))
  done
  printf '%s' "$template"
}

t() {
  # $1 = key; remaining args = interpolation values.
  local key="$1"; shift
  local active template
  active="$(active_language)"
  if template="$(catalog_lookup "$active" "$key")"; then
    :
  elif [ "$active" != "$DEFAULT_LANGUAGE" ] && template="$(catalog_lookup "$DEFAULT_LANGUAGE" "$key")"; then
    :
  else
    template="$key"
  fi
  interpolate "$template" "$@"
  printf '\n'
}

usage() {
  cat <<EOF
usage: $PROG <command> [args...]

Commands:
  t <key> [args...]   print the localized string for <key> in the active
                      language (fallback: active -> en -> the key itself).
                      {0} {1} ... placeholders are filled by positional args.
  lang                 print the resolved active language (en or pt-BR)
  -h, --help           show this help

Active language comes from [settings] language in the shared config
(\$XDG_CONFIG_HOME/spawnterm/config.toml). Default en. Reads never create a file.
EOF
}

main() {
  if [ "$#" -eq 0 ]; then
    err "missing command"
    usage >&2
    return 2
  fi

  local command="$1"; shift
  case "$command" in
    -h|--help|help)
      usage
      return 0
      ;;
    lang)
      active_language
      printf '\n'
      return 0
      ;;
    t)
      if [ "$#" -lt 1 ]; then
        err "t requires a <key>"
        return 2
      fi
      t "$@"
      return 0
      ;;
    *)
      err "unknown command: $command"
      usage >&2
      return 2
      ;;
  esac
}

main "$@"
