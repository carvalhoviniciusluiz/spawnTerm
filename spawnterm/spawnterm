#!/usr/bin/env sh
# spawnterm — thin umbrella dispatcher (#56).
#
# A convenience front door so `spawnterm help` works from a spawned agent's tab.
# It does NOT re-implement anything: `help` (and the no-arg case) delegate to the
# sibling `spawnterm-help`; any other subcommand <cmd> is forwarded to the
# sibling `spawnterm-<cmd>` (e.g. `spawnterm flag list` -> `spawnterm-flag list`).
#
# scope:external-tooling — pure shell glue; never modifies iTerm2 source.
set -u

PROG="spawnterm"

script_dir() {
	d="$(dirname "$0")"
	(cd "$d" 2>/dev/null && pwd)
}

SD="$(script_dir)"

usage() {
	cat <<EOF
$PROG — spawnTerm umbrella dispatcher.

Usage:
  $PROG help              Print the capability guide (delegates to spawnterm-help).
  $PROG <cmd> [args...]   Run the sibling tool spawnterm-<cmd> (e.g. flag, emit,
                          spawn, broker, review, janitor, cost, inbox, mcp, tmux).
  $PROG -h | --help       Show this help.
EOF
}

# Resolve a sibling tool: prefer the copy next to this script, else PATH.
resolve_tool() {
	# $1 = tool basename, e.g. spawnterm-help
	if [ -n "$SD" ] && [ -x "$SD/$1" ]; then
		printf '%s/%s' "$SD" "$1"
		return 0
	fi
	if command -v "$1" >/dev/null 2>&1; then
		command -v "$1"
		return 0
	fi
	return 1
}

if [ "$#" -eq 0 ]; then
	# No subcommand: show the guide (most useful default for a fresh agent).
	set -- help
fi

sub="$1"; shift

case "$sub" in
	-h|--help)
		usage
		exit 0
		;;
	help)
		if tool="$(resolve_tool spawnterm-help)"; then
			exec "$tool" "$@"
		fi
		printf '%s: spawnterm-help not found\n' "$PROG" >&2
		exit 1
		;;
	*)
		if tool="$(resolve_tool "spawnterm-$sub")"; then
			exec "$tool" "$@"
		fi
		printf '%s: unknown subcommand: %s (no spawnterm-%s found)\n' "$PROG" "$sub" "$sub" >&2
		usage >&2
		exit 2
		;;
esac
