#!/usr/bin/env sh
# spawnterm-inbox — the human-attention inbox CLI/TUI (#17).
#
# spawnTerm Tier 3 (#17). scope:external-tooling — pure policy + workflow glue
# over the broker (#4, durable queue) and the emitter (#7, attention). Never
# imports or modifies iTerm2 source.
#
# This is a thin launcher: the whole CLI is the Python module spawnterm_inbox.py
# (which talks to the broker via the in-repo BrokerClient). Unlike spawnterm-emit
# / spawnterm-flag, there is no shell parity twin — the inbox is inherently
# Python (it speaks the broker's socket protocol through the shared client).
#
# Gating: every subcommand honors the feature flag spawnterm.agent_inbox
# (default OFF); when OFF the inbox is a no-op. Bypass with --no-gate or
# SPAWNTERM_FORCE=1. See spawnterm/inbox/README.md.
here=$(cd "$(dirname "$0")" && pwd)
exec python3 "$here/spawnterm_inbox.py" "$@"
